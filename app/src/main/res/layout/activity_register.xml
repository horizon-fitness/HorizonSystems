<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayout"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/landing_background"
    android:fitsSystemWindows="true">

    <!-- Premium Ambient Glow -->
    <View
        android:layout_width="500dp"
        android:layout_height="500dp"
        android:alpha="0.15"
        android:background="@drawable/ambient_glow"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginEnd="-250dp"
        android:layout_marginTop="-200dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

            <LinearLayout
                android:id="@+id/innerLayout"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:paddingHorizontal="32dp"
                android:paddingTop="40dp"
                android:paddingBottom="40dp"
                android:gravity="center_horizontal">

            <!-- Header Bar -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="-12dp">

                <!-- Back Button -->
                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_alignParentStart="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_back_arrow"
                    app:tint="@color/white"
                    android:contentDescription="Back" />

                <!-- Clear Button -->
                <TextView
                    android:id="@+id/btnClearAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="12dp"
                    android:padding="8dp"
                    android:text="CLEAR ALL"
                    android:textColor="#80FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless" />
            </RelativeLayout>

            <!-- Gym Logo Header -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/gymLogoContainer"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginTop="8dp"
                android:visibility="gone"
                app:cardBackgroundColor="#1AFFFFFF"
                app:cardCornerRadius="40dp"
                app:cardElevation="0dp">
                <ImageView
                    android:id="@+id/registerGymLogo"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/horizon_logo"
                    android:scaleType="centerInside" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Header -->
            <TextView
                android:id="@+id/registerTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Join the Family"
                android:textColor="@color/white"
                android:textSize="36sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="-0.02" />

            <TextView
                android:id="@+id/registerSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Experience the Horizon difference."
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:alpha="0.8" />

            <!-- Progress Indicator -->
            <TextView
                android:id="@+id/registerStepIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Step 1 of 4: Account Access"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:fontFamily="sans-serif-black" />

            <!-- Step 1: Account Access -->
            <LinearLayout
                android:id="@+id/layoutStepAccount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:layout_gravity="center_horizontal"
                    android:text="ACCOUNT ACCESS"
                    android:textColor="#80FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="16dp">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/gymIdLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        app:hintEnabled="false"
                        app:errorEnabled="true"
                        app:startIconDrawable="@android:drawable/ic_menu_myplaces"
                        app:startIconTint="#80FFFFFF"
                        app:boxBackgroundMode="none">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/gymIdEdit"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/input_field_bg"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:hint="Tenant Code * (Ex: COR-1234)"
                            android:textColor="@color/white"
                            android:textColorHint="#40FFFFFF"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/userRegLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        app:hintEnabled="false"
                        app:errorEnabled="true"
                        app:startIconDrawable="@android:drawable/ic_menu_myplaces"
                        app:startIconTint="#80FFFFFF"
                        app:boxBackgroundMode="none">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/userRegEdit"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/input_field_bg"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:hint="Username *"
                            android:textColor="@color/white"
                            android:textColorHint="#40FFFFFF"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/passRegLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        app:hintEnabled="false"
                        app:errorEnabled="true"
                        app:startIconDrawable="@android:drawable/ic_lock_idle_lock"
                        app:startIconTint="#80FFFFFF"
                        app:endIconMode="password_toggle"
                        app:endIconTint="#80FFFFFF"
                        app:boxBackgroundMode="none">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/passRegEdit"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/input_field_bg"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:hint="Password *"
                            android:inputType="textPassword"
                            android:textColor="@color/white"
                            android:textColorHint="#40FFFFFF"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/confirmPassRegLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        app:hintEnabled="false"
                        app:errorEnabled="true"
                        app:startIconDrawable="@android:drawable/ic_lock_idle_lock"
                        app:startIconTint="#80FFFFFF"
                        app:endIconMode="password_toggle"
                        app:endIconTint="#80FFFFFF"
                        app:boxBackgroundMode="none">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/confirmPassRegEdit"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/input_field_bg"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:hint="Confirm Password *"
                            android:inputType="textPassword"
                            android:textColor="@color/white"
                            android:textColorHint="#40FFFFFF"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Password Requirements Checklist -->
                    <LinearLayout
                        android:id="@+id/passwordReqContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="0dp"
                        android:layout_marginHorizontal="8dp">

                        <TextView
                            android:id="@+id/reqLen"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="• Minimum 8 characters"
                            android:textColor="#40FFFFFF"
                            android:textSize="12sp"
                            android:paddingVertical="2dp" />

                        <TextView
                            android:id="@+id/reqNum"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="• At least 1 number"
                            android:textColor="#40FFFFFF"
                            android:textSize="12sp"
                            android:paddingVertical="2dp" />

                        <TextView
                            android:id="@+id/reqSpecial"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="• At least 1 special character (@#$%...)"
                            android:textColor="#40FFFFFF"
                            android:textSize="12sp"
                            android:paddingVertical="2dp" />

                        <TextView
                            android:id="@+id/reqCaps"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="• At least 1 uppercase letter"
                            android:textColor="#40FFFFFF"
                            android:textSize="12sp"
                            android:paddingVertical="2dp" />
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>

            <!-- Step 2: Personal Information -->
            <LinearLayout
                android:id="@+id/layoutStepPersonal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:layout_gravity="center_horizontal"
                    android:text="PERSONAL INFORMATION"
                    android:textColor="#80FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="16dp">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/firstNameLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        app:hintEnabled="false"
                        app:errorEnabled="true"
                        app:startIconDrawable="@android:drawable/ic_menu_directions"
                        app:startIconTint="#80FFFFFF"
                        app:boxBackgroundMode="none">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/firstNameEdit"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/input_field_bg"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:hint="First Name *"
                            android:textColor="@color/white"
                            android:textColorHint="#40FFFFFF"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/lastNameLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        app:hintEnabled="false"
                        app:errorEnabled="true"
                        app:startIconDrawable="@android:drawable/ic_menu_directions"
                        app:startIconTint="#80FFFFFF"
                        app:boxBackgroundMode="none">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/lastNameEdit"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/input_field_bg"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:hint="Last Name *"
                            android:textColor="@color/white"
                            android:textColorHint="#40FFFFFF"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/middleNameLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        app:hintEnabled="false"
                        app:startIconDrawable="@android:drawable/ic_menu_myplaces"
                        app:startIconTint="#80FFFFFF"
                        app:boxBackgroundMode="none">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/middleNameEdit"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/input_field_bg"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:hint="Middle Name (Optional)"
                            android:textColor="@color/white"
                            android:textColorHint="#40FFFFFF"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/birthDateLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        app:hintEnabled="false"
                        app:errorEnabled="true"
                        app:startIconDrawable="@android:drawable/ic_menu_today"
                        app:startIconTint="#80FFFFFF"
                        app:boxBackgroundMode="none">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/birthDateEdit"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/input_field_bg"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:hint="Birth Date *"
                            android:text="2000-01-01"
                            android:textColor="@color/white"
                            android:textColorHint="#40FFFFFF"
                            android:textSize="14sp"
                            android:focusable="false"
                            android:clickable="true"
                            android:inputType="none" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Parental Info (Dynamic) -->
                    <LinearLayout
                        android:id="@+id/parentalInfoSection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:layout_marginBottom="6dp"
                            android:text="PARENT / GUARDIAN INFORMATION (MINOR)"
                            android:textColor="@color/nav_active_color"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/parentNameLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="6dp"
                            app:hintEnabled="false"
                            app:errorEnabled="true"
                            app:startIconDrawable="@android:drawable/ic_menu_myplaces"
                            app:startIconTint="#80FFFFFF"
                            app:boxBackgroundMode="none">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/parentNameEdit"
                                android:layout_width="match_parent"
                                android:layout_height="56dp"
                                android:background="@drawable/input_field_bg"
                                android:gravity="center_vertical"
                                android:paddingHorizontal="16dp"
                                android:hint="Parent/Guardian Full Name *"
                                android:textColor="@color/white"
                                android:textColorHint="#40FFFFFF"
                                android:textSize="14sp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/parentPhoneLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="6dp"
                            app:hintEnabled="false"
                            app:errorEnabled="true"
                            app:startIconDrawable="@android:drawable/ic_menu_call"
                            app:startIconTint="#80FFFFFF"
                            app:boxBackgroundMode="none">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/parentPhoneEdit"
                                android:layout_width="match_parent"
                                android:layout_height="56dp"
                                android:background="@drawable/input_field_bg"
                                android:gravity="center_vertical"
                                android:paddingHorizontal="16dp"
                                android:hint="Parent Contact Number *"
                                android:textColor="@color/white"
                                android:textColorHint="#40FFFFFF"
                                android:textSize="14sp"
                                android:inputType="phone" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/sexLayout"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        app:hintEnabled="false"
                        app:errorEnabled="true"
                        app:startIconDrawable="@android:drawable/ic_menu_search"
                        app:startIconTint="#80FFFFFF"
                        app:endIconTint="#80FFFFFF">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/sexSpinner"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/input_field_bg"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:hint="Sex *"
                            android:textColor="@color/white"
                            android:textColorHint="#40FFFFFF"
                            android:textSize="14sp"
                            android:inputType="none" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Step 3: Contact Details -->
            <LinearLayout
                android:id="@+id/layoutStepContact"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:layout_gravity="center_horizontal"
                    android:text="CONTACT DETAILS"
                    android:textColor="#80FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="16dp">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/emailLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        app:hintEnabled="false"
                        app:errorEnabled="true"
                        app:startIconDrawable="@android:drawable/ic_dialog_email"
                        app:startIconTint="#80FFFFFF"
                        app:boxBackgroundMode="none">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/emailEdit"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/input_field_bg"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:hint="Email Address *"
                            android:inputType="textEmailAddress"
                            android:textColor="@color/white"
                            android:textColorHint="#40FFFFFF"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/phoneNumberLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        app:hintEnabled="false"
                        app:errorEnabled="true"
                        app:startIconDrawable="@android:drawable/ic_menu_call"
                        app:startIconTint="#80FFFFFF"
                        app:boxBackgroundMode="none">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/phoneNumberEdit"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/input_field_bg"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:hint="Contact Number *"
                            android:inputType="phone"
                            android:textColor="@color/white"
                            android:textColorHint="#40FFFFFF"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/addressLineLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        app:hintEnabled="false"
                        app:errorEnabled="true"
                        app:startIconDrawable="@android:drawable/ic_dialog_map"
                        app:startIconTint="#80FFFFFF"
                        app:boxBackgroundMode="none">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/addressLineEdit"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/input_field_bg"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:hint="Street Address *"
                            android:textColor="@color/white"
                            android:textColorHint="#40FFFFFF"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/barangayLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        app:hintEnabled="false"
                        app:errorEnabled="true"
                        app:startIconDrawable="@android:drawable/ic_dialog_map"
                        app:startIconTint="#80FFFFFF"
                        app:boxBackgroundMode="none">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/barangayEdit"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/input_field_bg"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:hint="Barangay *"
                            android:textColor="@color/white"
                            android:textColorHint="#40FFFFFF"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/cityLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        app:hintEnabled="false"
                        app:errorEnabled="true"
                        app:startIconDrawable="@android:drawable/ic_dialog_map"
                        app:startIconTint="#80FFFFFF"
                        app:boxBackgroundMode="none">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/cityEdit"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/input_field_bg"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:hint="City/Municipality *"
                            android:textColor="@color/white"
                            android:textColorHint="#40FFFFFF"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/provinceLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        app:hintEnabled="false"
                        app:errorEnabled="true"
                        app:startIconDrawable="@android:drawable/ic_dialog_map"
                        app:startIconTint="#80FFFFFF"
                        app:boxBackgroundMode="none">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/provinceEdit"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/input_field_bg"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:hint="Province *"
                            android:textColor="@color/white"
                            android:textColorHint="#40FFFFFF"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/regionLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        app:hintEnabled="false"
                        app:errorEnabled="true"
                        app:startIconDrawable="@android:drawable/ic_dialog_map"
                        app:startIconTint="#80FFFFFF"
                        app:boxBackgroundMode="none">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/regionEdit"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/input_field_bg"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:hint="Region *"
                            android:textColor="@color/white"
                            android:textColorHint="#40FFFFFF"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/occupationLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        app:hintEnabled="false"
                        app:startIconDrawable="@android:drawable/ic_menu_info_details"
                        app:startIconTint="#80FFFFFF"
                        app:boxBackgroundMode="none">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/occupationEdit"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/input_field_bg"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:hint="Occupation (Optional)"
                            android:textColor="@color/white"
                            android:textColorHint="#40FFFFFF"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Step 4: Health & Background -->
            <LinearLayout
                android:id="@+id/layoutStepHealth"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:layout_gravity="center_horizontal"
                    android:text="HEALTH &amp; BACKGROUND"
                    android:textColor="#80FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="16dp">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/medicalHistoryLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        app:hintEnabled="false"
                        app:startIconDrawable="@android:drawable/ic_menu_info_details"
                        app:startIconTint="#80FFFFFF"
                        app:boxBackgroundMode="none">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/medicalHistoryEdit"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/input_field_bg"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:hint="Medical History (Optional)"
                            android:textColor="@color/white"
                            android:textColorHint="#40FFFFFF"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/emergencyNameLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        app:hintEnabled="false"
                        app:errorEnabled="true"
                        app:startIconDrawable="@android:drawable/ic_menu_myplaces"
                        app:startIconTint="#80FFFFFF"
                        app:boxBackgroundMode="none">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/emergencyNameEdit"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/input_field_bg"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:hint="Emergency Contact Name *"
                            android:textColor="@color/white"
                            android:textColorHint="#40FFFFFF"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/emergencyPhoneLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        app:hintEnabled="false"
                        app:errorEnabled="true"
                        app:startIconDrawable="@android:drawable/ic_menu_call"
                        app:startIconTint="#80FFFFFF"
                        app:boxBackgroundMode="none">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/emergencyPhoneEdit"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/input_field_bg"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:hint="Emergency Contact Number *"
                            android:inputType="phone"
                            android:textColor="@color/white"
                            android:textColorHint="#40FFFFFF"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Navigation Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="20dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPrev"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="Previous"
                    android:textAllCaps="false"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    app:backgroundTint="@null"
                    android:background="@drawable/button_premium"
                    android:fontFamily="sans-serif-black"
                    android:visibility="gone" />

                <View
                    android:id="@+id/btnSpace"
                    android:layout_width="16dp"
                    android:layout_height="match_parent"
                    android:visibility="gone" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnNext"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="Next Step"
                    android:textAllCaps="false"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    app:backgroundTint="@null"
                    android:background="@drawable/button_premium"
                    android:fontFamily="sans-serif-black" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRegister"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="Create Account"
                    android:textAllCaps="false"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    app:backgroundTint="@null"
                    android:background="@drawable/button_premium"
                    android:visibility="gone"
                    android:fontFamily="sans-serif-black" />
            </LinearLayout>

            <!-- Universal Footer link -->
            <LinearLayout
                android:id="@+id/registerFooter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="24dp"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Already part of the family?"
                    android:textColor="#80FFFFFF"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginEnd="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:id="@+id/btnSignBack"
                    android:text="Sign In"
                    android:textColor="@color/nav_active_color"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-black"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:text="© 2026 HORIZON SYSTEM"
                android:textColor="#66FFFFFF"
                android:textSize="10sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.1" />

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
