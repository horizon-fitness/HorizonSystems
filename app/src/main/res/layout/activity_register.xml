<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/landing_background"
    android:fitsSystemWindows="true">

    <!-- Premium Ambient Glow -->
    <View
        android:layout_width="500dp"
        android:layout_height="500dp"
        android:alpha="0.15"
        android:background="@drawable/ambient_glow"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginEnd="-250dp"
        android:layout_marginTop="-200dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="32dp"
            android:paddingTop="32dp"
            android:paddingBottom="60dp">

            <!-- Back Button -->
            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_back_arrow"
                android:layout_marginStart="-12dp"
                app:tint="@color/white"
                android:contentDescription="Back" />

            <!-- Header -->
            <TextView
                android:id="@+id/registerTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Join the Family"
                android:textColor="@color/white"
                android:textSize="32sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="-0.02" />

            <TextView
                android:id="@+id/registerSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Experience the Horizon difference."
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:alpha="0.8" />

            <!-- Section: Account Access -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:text="ACCOUNT ACCESS"
                android:textColor="@color/landing_primary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="62dp"
                    android:background="@drawable/input_field_bg"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="20dp"
                    android:layout_marginBottom="12dp">
                    <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@android:drawable/ic_menu_myplaces" app:tint="#80FFFFFF" />
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/gymIdEdit"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginStart="16dp"
                        android:background="@null"
                        android:hint="Tenant Code"
                        android:textColor="@color/white"
                        android:textColorHint="#40FFFFFF"
                        android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="62dp"
                    android:background="@drawable/input_field_bg"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="20dp"
                    android:layout_marginBottom="12dp">
                    <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@android:drawable/ic_menu_my_calendar" app:tint="#80FFFFFF" />
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/userRegEdit"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginStart="16dp"
                        android:background="@null"
                        android:hint="Create Username"
                        android:textColor="@color/white"
                        android:textColorHint="#40FFFFFF"
                        android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="62dp"
                    android:background="@drawable/input_field_bg"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="20dp">
                    <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@android:drawable/ic_lock_idle_lock" app:tint="#80FFFFFF" />
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/passRegEdit"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginStart="16dp"
                        android:background="@null"
                        android:hint="Secure Password"
                        android:inputType="textPassword"
                        android:textColor="@color/white"
                        android:textColorHint="#40FFFFFF"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Section: Personal Information -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="PERSONAL INFORMATION"
                android:textColor="@color/landing_primary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="62dp" android:background="@drawable/input_field_bg" android:gravity="center_vertical" android:paddingHorizontal="20dp" android:layout_marginBottom="12dp">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/firstNameEdit" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@null" android:hint="First Name" android:textColor="@color/white" android:textColorHint="#40FFFFFF" android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="62dp" android:background="@drawable/input_field_bg" android:gravity="center_vertical" android:paddingHorizontal="20dp" android:layout_marginBottom="12dp">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/lastNameEdit" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@null" android:hint="Last Name" android:textColor="@color/white" android:textColorHint="#40FFFFFF" android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="62dp" android:background="@drawable/input_field_bg" android:gravity="center_vertical" android:paddingHorizontal="20dp" android:layout_marginBottom="12dp">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/middleNameEdit" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@null" android:hint="Middle Name (Optional)" android:textColor="@color/white" android:textColorHint="#40FFFFFF" android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="62dp" android:background="@drawable/input_field_bg" android:gravity="center_vertical" android:paddingHorizontal="20dp" android:layout_marginBottom="12dp">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/emailEdit" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@null" android:hint="Email Address" android:inputType="textEmailAddress" android:textColor="@color/white" android:textColorHint="#40FFFFFF" android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="62dp" android:background="@drawable/input_field_bg" android:gravity="center_vertical" android:paddingHorizontal="20dp" android:layout_marginBottom="12dp">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/phoneNumberEdit" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@null" android:hint="Phone Number" android:inputType="phone" android:textColor="@color/white" android:textColorHint="#40FFFFFF" android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="12dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="62dp" android:layout_weight="1.2" android:background="@drawable/input_field_bg" android:gravity="center_vertical" android:paddingHorizontal="20dp">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/birthDateEdit" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@null" android:hint="Birth Date" android:text="2000-01-01" android:textColor="@color/white" android:textColorHint="#40FFFFFF" android:textSize="13sp" />
                    </LinearLayout>
                    <View android:layout_width="12dp" android:layout_height="0dp" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="62dp" android:layout_weight="0.8" android:background="@drawable/input_field_bg" android:gravity="center_vertical" android:paddingHorizontal="20dp">
                        <AutoCompleteTextView android:id="@+id/sexSpinner" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@null" android:hint="Sex" android:textColor="@color/white" android:textColorHint="#40FFFFFF" android:textSize="13sp" android:inputType="none" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="62dp" android:background="@drawable/input_field_bg" android:gravity="center_vertical" android:paddingHorizontal="20dp" android:layout_marginBottom="12dp">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/occupationEdit" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@null" android:hint="Occupation" android:textColor="@color/white" android:textColorHint="#40FFFFFF" android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="100dp" android:background="@drawable/input_field_bg" android:gravity="top|start" android:padding="16dp">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/addressEdit" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@null" android:hint="Full Residential Address" android:textColor="@color/white" android:textColorHint="#40FFFFFF" android:textSize="14sp" android:gravity="top" android:inputType="textMultiLine" />
                </LinearLayout>
            </LinearLayout>

            <!-- Section: Medical & Emergency -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="HEALTH &amp; EMERGENCY"
                android:textColor="@color/landing_primary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="100dp" android:background="@drawable/input_field_bg" android:gravity="top|start" android:padding="16dp" android:layout_marginBottom="12dp">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/medicalHistoryEdit" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@null" android:hint="Medical History / Allergies" android:textColor="@color/white" android:textColorHint="#40FFFFFF" android:textSize="14sp" android:gravity="top" android:inputType="textMultiLine" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="62dp" android:background="@drawable/input_field_bg" android:gravity="center_vertical" android:paddingHorizontal="20dp" android:layout_marginBottom="12dp">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/emergencyNameEdit" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@null" android:hint="Emergency Contact Name" android:textColor="@color/white" android:textColorHint="#40FFFFFF" android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="62dp" android:background="@drawable/input_field_bg" android:gravity="center_vertical" android:paddingHorizontal="20dp" android:layout_marginBottom="40dp">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/emergencyPhoneEdit" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@null" android:hint="Emergency Phone Number" android:inputType="phone" android:textColor="@color/white" android:textColorHint="#40FFFFFF" android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Register Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRegister"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="Create Account"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                app:backgroundTint="@null"
                android:background="@drawable/button_premium"
                app:elevation="4dp"
                android:fontFamily="sans-serif-black" />

            <!-- Footer -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="32dp"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Already part of the family? "
                    android:textColor="#80FFFFFF"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sign In"
                    android:textColor="@color/landing_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-black"
                    android:clickable="true"
                    android:focusable="true"
                    android:onClick="onBackPressed" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:gravity="center"
                android:text="© 2026 HORIZON SYSTEM"
                android:textColor="#1AFFFFFF"
                android:textSize="10sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.1" />

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
