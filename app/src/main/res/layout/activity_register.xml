<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/landing_background"
    android:fitsSystemWindows="true">

    <!-- Subtle Ambient Glow -->
    <View
        android:layout_width="450dp"
        android:layout_height="450dp"
        android:alpha="0.2"
        android:background="@drawable/ambient_glow"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginEnd="-200dp"
        android:layout_marginTop="-200dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="28dp">

            <TextView
                android:id="@+id/registerTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Create Profile"
                android:textColor="@color/white"
                android:textSize="32sp"
                android:textStyle="bold"
                android:letterSpacing="-0.02"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/registerSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Complete your membership details"
                android:textColor="@color/text_secondary"
                android:textSize="15sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/registerTitle" />

            <!-- Section: Account Information -->
            <TextView
                android:id="@+id/sectionAccount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:text="ACCOUNT ACCESS"
                android:textColor="@color/landing_primary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"
                app:layout_constraintTop_toBottomOf="@id/registerSubtitle"
                app:layout_constraintStart_toStartOf="parent" />

            <LinearLayout
                android:id="@+id/accountGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="12dp"
                app:layout_constraintTop_toBottomOf="@id/sectionAccount">

                 <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Gym ID (Tenant)"
                    android:textColorHint="#40FFFFFF"
                    app:boxStrokeColor="@color/landing_primary"
                    app:hintTextColor="@color/landing_primary"
                    app:startIconDrawable="@android:drawable/ic_menu_myplaces"
                    app:startIconTint="#40FFFFFF">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/gymIdEdit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:paddingVertical="16dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Username"
                    android:textColorHint="#40FFFFFF"
                    app:boxStrokeColor="@color/landing_primary"
                    app:hintTextColor="@color/landing_primary"
                    app:startIconDrawable="@android:drawable/ic_menu_my_calendar"
                    app:startIconTint="#40FFFFFF">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/userRegEdit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:paddingVertical="16dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Initial Password"
                    android:textColorHint="#40FFFFFF"
                    app:boxStrokeColor="@color/landing_primary"
                    app:endIconMode="password_toggle"
                    app:endIconTint="#40FFFFFF"
                    app:hintTextColor="@color/landing_primary"
                    app:startIconDrawable="@android:drawable/ic_lock_idle_lock"
                    app:startIconTint="#40FFFFFF">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/passRegEdit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:paddingVertical="16dp" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- Section: Personal Information -->
            <TextView
                android:id="@+id/sectionPersonal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="PERSONAL INFORMATION"
                android:textColor="@color/landing_primary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"
                app:layout_constraintTop_toBottomOf="@id/accountGroup"
                app:layout_constraintStart_toStartOf="parent" />

            <LinearLayout
                android:id="@+id/personalGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="12dp"
                app:layout_constraintTop_toBottomOf="@id/sectionPersonal">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="First Name"
                        android:textColorHint="#40FFFFFF"
                        app:boxStrokeColor="@color/landing_primary"
                        app:hintTextColor="@color/landing_primary">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/firstNameEdit"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:paddingVertical="16dp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <View android:layout_width="12dp" android:layout_height="0dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Last Name"
                        android:textColorHint="#40FFFFFF"
                        app:boxStrokeColor="@color/landing_primary"
                        app:hintTextColor="@color/landing_primary">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/lastNameEdit"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:paddingVertical="16dp" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Middle Name"
                    android:textColorHint="#40FFFFFF"
                    app:boxStrokeColor="@color/landing_primary"
                    app:hintTextColor="@color/landing_primary">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/middleNameEdit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:paddingVertical="16dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Birth Date"
                    android:textColorHint="#40FFFFFF"
                    app:boxStrokeColor="@color/landing_primary"
                    app:hintTextColor="@color/landing_primary">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/birthDateEdit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="date"
                        android:text="2000-01-01"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:paddingVertical="16dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Sex"
                    android:textColorHint="#40FFFFFF"
                    app:boxStrokeColor="@color/landing_primary"
                    app:hintTextColor="@color/landing_primary">
                    <AutoCompleteTextView
                        android:id="@+id/sexSpinner"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:paddingVertical="16dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Occupation"
                    android:textColorHint="#40FFFFFF"
                    app:boxStrokeColor="@color/landing_primary"
                    app:hintTextColor="@color/landing_primary">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/occupationEdit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:paddingVertical="16dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Full Address"
                    android:textColorHint="#40FFFFFF"
                    app:boxStrokeColor="@color/landing_primary"
                    app:hintTextColor="@color/landing_primary">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/addressEdit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:paddingVertical="16dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Email Address"
                    android:textColorHint="#40FFFFFF"
                    app:boxStrokeColor="@color/landing_primary"
                    app:hintTextColor="@color/landing_primary">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/emailEdit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textEmailAddress"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:paddingVertical="16dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Phone Number"
                    android:textColorHint="#40FFFFFF"
                    app:boxStrokeColor="@color/landing_primary"
                    app:hintTextColor="@color/landing_primary">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/phoneNumberEdit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="phone"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:paddingVertical="16dp" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- Section: Health & Emergency -->
            <TextView
                android:id="@+id/sectionEmergency"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="HEALTH &amp; EMERGENCY"
                android:textColor="@color/landing_primary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"
                app:layout_constraintTop_toBottomOf="@id/personalGroup"
                app:layout_constraintStart_toStartOf="parent" />

            <LinearLayout
                android:id="@+id/emergencyGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="12dp"
                app:layout_constraintTop_toBottomOf="@id/sectionEmergency">

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Medical History / Allergies"
                    android:textColorHint="#40FFFFFF"
                    app:boxStrokeColor="@color/landing_primary"
                    app:hintTextColor="@color/landing_primary">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/medicalHistoryEdit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:paddingVertical="16dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Emergency Contact Name"
                    android:textColorHint="#40FFFFFF"
                    app:boxStrokeColor="@color/landing_primary"
                    app:hintTextColor="@color/landing_primary">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/emergencyNameEdit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:paddingVertical="16dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Emergency Contact Phone"
                    android:textColorHint="#40FFFFFF"
                    app:boxStrokeColor="@color/landing_primary"
                    app:hintTextColor="@color/landing_primary">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/emergencyPhoneEdit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="phone"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:paddingVertical="16dp" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRegister"
                android:layout_width="match_parent"
                android:layout_height="62dp"
                android:layout_marginTop="48dp"
                android:layout_marginBottom="40dp"
                android:text="Create Account"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="@color/landing_primary"
                app:cornerRadius="18dp"
                app:layout_constraintTop_toBottomOf="@id/emergencyGroup"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
