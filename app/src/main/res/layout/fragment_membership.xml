<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="32dp"
        android:paddingBottom="48dp"
        android:clipChildren="false">

        <!-- Header Padding Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="bottom">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CHOOSE YOUR "
                    android:textColor="@color/white"
                    android:textSize="28sp"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="-0.02" />

                <TextView
                    android:id="@+id/tv_membership_theme_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="STRENGTH"
                    android:textColor="#8c2bee"
                    android:textSize="28sp"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="-0.02" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutPlanSelectionHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="8dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="SELECT A PLAN TO UNLOCK FULL ACCESS"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.05" />
            </LinearLayout>

            <!-- Loading Indicator -->
            <ProgressBar
                android:id="@+id/membershipLoading"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="32dp"
                android:visibility="visible" />

            <!-- Active Membership Card (Clean Home Style) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardActiveMembership"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:visibility="gone"
                app:cardBackgroundColor="#0D0D10"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="#1AFFFFFF"
                app:strokeWidth="1dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="24dp">

                    <!-- Header Row -->
                    <TextView
                        android:id="@+id/tvStatusLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CURRENT STATUS"
                        android:textColor="#A855F7"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.05"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent" />

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cvActiveBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="#0FFFFFFF"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:strokeColor="#A855F7"
                        app:strokeWidth="1dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toEndOf="parent">
                        
                        <TextView
                            android:id="@+id/tvActivePlanStatusBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="4dp"
                            android:text="ACTIVE"
                            android:textColor="#A855F7"
                            android:textSize="10sp"
                            android:fontFamily="sans-serif-black" />
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Plan Name -->
                    <TextView
                        android:id="@+id/tvActivePlanName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="MONTHLY PASS"
                        android:textColor="@color/white"
                        android:textSize="28sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="-0.02"
                        app:layout_constraintTop_toBottomOf="@id/tvStatusLabel"
                        app:layout_constraintStart_toStartOf="parent" />

                    <!-- Info Grid -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="32dp"
                        android:orientation="horizontal"
                        app:layout_constraintTop_toBottomOf="@id/tvActivePlanName"
                        app:layout_constraintBottom_toBottomOf="parent">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="LAST BILLING"
                                android:textColor="@color/text_secondary"
                                android:alpha="0.4"
                                android:textSize="10sp"
                                android:fontFamily="sans-serif-black"
                                android:letterSpacing="0.05" />

                            <TextView
                                android:id="@+id/tvActivePlanStart"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="Oct 16, 2023"
                                android:textColor="@color/white"
                                android:textSize="15sp"
                                android:fontFamily="sans-serif-black" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="NEXT PAYMENT"
                                android:textColor="@color/text_secondary"
                                android:alpha="0.4"
                                android:textSize="10sp"
                                android:fontFamily="sans-serif-black"
                                android:letterSpacing="0.05" />

                            <TextView
                                android:id="@+id/tvActivePlanDuration"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="Nov 16, 2023"
                                android:textColor="#A855F7"
                                android:textSize="15sp"
                                android:fontFamily="sans-serif-black" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Dynamic Plan Selection (Fixed Clipping) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPlanSelection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            android:clipToPadding="false"
            android:clipChildren="false"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="12dp"
            android:paddingBottom="24dp"
            android:visibility="gone"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

        <LinearLayout
            android:id="@+id/emptyStateMembership"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="40dp"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <ImageView
                android:id="@+id/ivEmptyMembership"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_clock"
                android:alpha="0.1"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/tvNoMembershipPlans"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="No membership plan available"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:alpha="0.3"
                android:gravity="center" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp">

            <!-- Membership History Header (Styled after main header) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvHistoryHeaderPart1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MEMBERSHIP "
                    android:textColor="@color/white"
                    android:textSize="22sp"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="-0.02" />

                <TextView
                    android:id="@+id/tvHistoryHeaderPart2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HISTORY"
                    android:textColor="#A855F7"
                    android:textSize="22sp"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="-0.02" />
            </LinearLayout>

            <!-- Labs Search Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:id="@+id/containerSearchHistory"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_search_modern"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="12dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_search"
                        app:tint="@color/text_secondary"
                        android:alpha="0.4" />

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etSearchHistory"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:hint="Search history..."
                        android:textColor="@color/white"
                        android:textColorHint="#4DFFFFFF"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium"
                        android:paddingStart="8dp"
                        android:inputType="text"
                        android:imeOptions="actionSearch" />
                </LinearLayout>

                <ImageButton
                    android:id="@+id/btnSortHistory"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_action_icon"
                    android:src="@drawable/ic_sort"
                    app:tint="@color/white"
                    android:padding="12dp"
                    android:scaleType="centerInside" />

                <ImageButton
                    android:id="@+id/btnFilterHistory"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_action_icon"
                    android:src="@drawable/ic_tune"
                    app:tint="@color/white"
                    android:padding="12dp"
                    android:scaleType="centerInside" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="#1AFFFFFF"
                android:layout_marginBottom="8dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvMembershipHistory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="8dp"
                android:clipToPadding="false" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
