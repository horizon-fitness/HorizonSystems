<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootSheetContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:padding="28dp">

    <View
        android:layout_width="48dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="28dp"
        android:background="#33FFFFFF" />

    <TextView
        android:id="@+id/sheetTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CHECKOUT DETAILS"
        android:textColor="@color/white"
        android:textSize="22sp"
        android:fontFamily="sans-serif-black"
        android:textStyle="bold|italic"
        android:textAllCaps="true"
        android:letterSpacing="-0.02" />

    <TextView
        android:id="@+id/sheetPlanName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="MONTHLY PASS"
        android:textColor="#A855F7"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textAllCaps="true"
        android:letterSpacing="0.2" />

    <!-- Payment Mode Selection -->
    <TextView
        android:id="@+id/tvPaymentModeHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="PAYMENT OPTION"
        android:textColor="@color/text_secondary"
        android:textSize="9sp"
        android:textStyle="bold"
        android:textAllCaps="true"
        android:letterSpacing="0.15" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/cgPaymentMode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:singleSelection="true"
        app:selectionRequired="true">
        
        <com.google.android.material.chip.Chip
            android:id="@+id/chipFullPayment"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Full Payment"
            android:checked="true"
            app:chipBackgroundColor="#1AFFFFFF"
            app:chipStrokeColor="#33FFFFFF"
            app:chipStrokeWidth="1dp"
            android:textColor="@color/white"
            android:textSize="11sp" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipMonthlyPayment"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Monthly Installment"
            app:chipBackgroundColor="#1AFFFFFF"
            app:chipStrokeColor="#33FFFFFF"
            app:chipStrokeWidth="1dp"
            android:textColor="@color/white"
            android:textSize="11sp" />
    </com.google.android.material.chip.ChipGroup>

    <!-- Summary Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:cardBackgroundColor="#0DFFFFFF"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:strokeColor="#1AFFFFFF"
        app:strokeWidth="1dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">
            <TextView
                android:id="@+id/sheetPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₱1,500.00"
                android:textColor="@color/white"
                android:textSize="28sp"
                android:fontFamily="sans-serif-black"
                android:textStyle="bold|italic" />
            <TextView
                android:id="@+id/sheetDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Starts today, ends in 30 days"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:letterSpacing="0.02" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Terms Summary Header -->
    <TextView
        android:id="@+id/sheetTermsHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:text="SUMMARY &amp; TERMS"
        android:textColor="#A855F7"
        android:textSize="9sp"
        android:textStyle="bold"
        android:textAllCaps="true"
        android:letterSpacing="0.2" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardTerms"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:layout_marginTop="12dp"
        app:cardBackgroundColor="#05FFFFFF"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeColor="#0DFFFFFF"
        app:strokeWidth="1dp">
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1. AUTHORIZATION: By confirming, you authorize the gym to charge the total amount displayed. For subscription plans, you authorize recurring charges until you manually cancel.\n\n2. BILLING &amp; RENEWAL: Your account will be charged automatically at the start of every billing period. Price changes will be announced via email at least 30 days prior.\n\n3. CANCELLATION &amp; REFUNDS: You can cancel anytime via the Dashboard. Access continues until the current period ends. All sales are final; refunds are only issued for technical errors.\n\n4. SECURITY: We do not store full payment credentials on our servers. All transactions are processed via secure, encrypted third-party gateways."
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:lineSpacingExtra="5dp"
                android:fontFamily="sans-serif-medium" />
        </androidx.core.widget.NestedScrollView>
    </com.google.android.material.card.MaterialCardView>

    <!-- Agreement -->
    <CheckBox
        android:id="@+id/cbAgreement"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="I have read and understood the informative summary above and authorize this transaction."
        android:textColor="#80FFFFFF"
        android:textSize="11sp"
        android:buttonTint="#80FFFFFF"
        android:paddingStart="12dp"
        android:fontFamily="sans-serif-medium" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConfirmSheet"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginTop="28dp"
        android:text="CONFIRM &amp; PROCEED"
        android:textColor="@color/white"
        android:textSize="11sp"
        android:textStyle="bold|italic"
        android:textAllCaps="true"
        android:letterSpacing="0.1"
        android:enabled="false"
        app:cornerRadius="16dp"
        app:backgroundTint="#A855F7"
        app:icon="@drawable/ic_check_circle"
        app:iconGravity="textStart"
        app:iconPadding="12dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCancelSheet"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:text="CANCEL TRANSACTION"
        android:textColor="#EF4444"
        android:textSize="10sp"
        android:textStyle="bold"
        android:textAllCaps="true"
        android:letterSpacing="0.15"
        app:strokeColor="#EF4444"
        app:strokeWidth="1dp"
        app:cornerRadius="12dp"
        app:backgroundTint="@android:color/transparent" />

</LinearLayout>
