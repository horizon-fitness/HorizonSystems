<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/landing_background"
    android:fitsSystemWindows="true">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="32dp"
            android:paddingTop="60dp"
            android:paddingBottom="40dp">

            <!-- Header -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="40dp">
                
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBack"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:padding="0dp"
                    app:icon="@drawable/ic_back_arrow"
                    app:iconTint="@color/white"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    android:layout_alignParentStart="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="SWITCH GYM"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.1" />
            </RelativeLayout>

            <!-- Option 1: QR Scan -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Option 1: Scan QR Code"
                android:textColor="#CCFFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/qrCameraPlaceholder"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginBottom="40dp"
                app:cardBackgroundColor="#0DFFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#20FFFFFF"
                app:strokeWidth="1dp">
                
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:orientation="vertical">
                    
                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_qr_code"
                        app:tint="@color/nav_active_color"
                        android:alpha="0.8" />
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Tap to Start Scanning"
                        android:textColor="#80FFFFFF"
                        android:textSize="13sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Option 2: Tenant Code -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Option 2: Enter Tenant Code"
                android:textColor="#CCFFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/input_field_bg"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp">
                
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/tenantCodeEdit"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="LLL-NNNN"
                    android:textColor="@color/white"
                    android:textColorHint="#40FFFFFF"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"
                    android:textAllCaps="true" />
                
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnConnectCode"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="APPLY"
                    android:textColor="@color/nav_active_color"
                    android:textStyle="bold" />
            </LinearLayout>
            
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="40dp"
                android:text="Format example: HOR-2024"
                android:textColor="#40FFFFFF"
                android:textSize="11sp"
                android:paddingStart="8dp" />

            <!-- Option 3: Direct Link -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Option 3: Enter Gym Link"
                android:textColor="#CCFFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:background="@drawable/input_field_bg"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp">
                
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/gymLinkEdit"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="horizonfitness.com/gym-slug"
                    android:textColor="@color/white"
                    android:textColorHint="#40FFFFFF"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:inputType="textUri" />
                
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnConnectLink"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CONNECT"
                    android:textColor="@color/nav_active_color"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
