<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayout"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/landing_background"
    android:fitsSystemWindows="true">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="32dp"
            android:paddingTop="60dp"
            android:paddingBottom="40dp">

            <!-- Header -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp">
                
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBack"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:padding="0dp"
                    app:icon="@drawable/ic_back_arrow"
                    app:iconTint="@color/white"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    android:layout_alignParentStart="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="SWITCH GYM"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.1" />
            </RelativeLayout>

            <!-- Current Connection Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/currentGymCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                app:cardBackgroundColor="#0DFFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#20FFFFFF"
                app:strokeWidth="1dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">
                    
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        app:cardCornerRadius="24dp"
                        app:cardBackgroundColor="#20FFFFFF"
                        app:cardElevation="0dp">
                        <ImageView
                            android:id="@+id/currentGymLogo"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="0dp"
                            android:src="@drawable/horizon_logo"
                            android:scaleType="centerInside" />
                    </com.google.android.material.card.MaterialCardView>
                    
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Currently Connected To:"
                            android:textColor="#80FFFFFF"
                            android:textSize="11sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.05" />
                        
                        <TextView
                            android:id="@+id/currentGymName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Horizon Systems"
                            android:textColor="@color/white"
                            android:textSize="17sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                    
                    <ImageView
                        android:id="@+id/statusIcon"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_check_circle"
                        app:tint="@color/nav_active_color" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDisconnectGym"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="DISCONNECT"
                        android:textColor="#FF5252"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Loading Indicator -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:layout_marginBottom="24dp"
                android:visibility="gone"
                android:indeterminateTint="@color/nav_active_color" />

            <!-- Option 1: QR Scan -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Option 1: Scan QR Code"
                android:textColor="#CCFFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/qrCameraPlaceholder"
                android:layout_width="match_parent"
                android:layout_height="320dp"
                android:layout_marginBottom="40dp"
                app:cardBackgroundColor="#0DFFFFFF"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="#1AFFFFFF"
                app:strokeWidth="1dp">
                
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <androidx.camera.view.PreviewView
                        android:id="@+id/previewView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:visibility="invisible"
                        app:scaleType="fillCenter" />

                    <!-- Launch Trigger Overlay -->
                    <LinearLayout
                        android:id="@+id/layoutStartScanner"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:background="#1AFFFFFF"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/ivLaunchScannerIcon"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:src="@drawable/ic_qr_code"
                            app:tint="@color/white" />

                        <TextView
                            android:id="@+id/tvLaunchScannerLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:fontFamily="sans-serif-black"
                            android:letterSpacing="0.05"
                            android:text="TAP TO LAUNCH SCANNER"
                            android:textColor="@color/white"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Scanner Overlay (Stylized - Hidden initially) -->
                    <View
                        android:id="@+id/vScannerOverlay"
                        android:layout_width="200dp"
                        android:layout_height="200dp"
                        android:background="@drawable/badge_pill_border"
                        android:alpha="0.3"
                        android:visibility="gone"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <ImageView
                        android:id="@+id/ivScannerIcon"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_qr_code"
                        android:alpha="0.2"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Option 2: Tenant Code -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Option 2: Enter Tenant Code"
                android:textColor="#CCFFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/input_field_bg"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp">
                
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/tenantCodeEdit"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="LLL-NNNN"
                    android:textColor="@color/white"
                    android:textColorHint="#40FFFFFF"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"
                    android:textAllCaps="true" />
                
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnConnectCode"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CONNECT"
                    android:textColor="@color/nav_active_color"
                    android:textStyle="bold" />
            </LinearLayout>


            <!-- Option 3: Direct Link -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Option 3: Enter Gym Link"
                android:textColor="#CCFFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:background="@drawable/input_field_bg"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp">
                
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/gymLinkEdit"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="horizonfitness.com/gym-slug"
                    android:textColor="@color/white"
                    android:textColorHint="#40FFFFFF"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:inputType="textUri" />
                
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnConnectLink"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CONNECT"
                    android:textColor="@color/nav_active_color"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Instruction Footer -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="48dp"
                android:gravity="center"
                android:text="You can find the Gym QR, Tenant Code, or Link\non your gym's official dashboard or webpage."
                android:textColor="#66FFFFFF"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:lineSpacingExtra="4dp"
                android:alpha="0.8" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
