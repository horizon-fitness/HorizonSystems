<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/workoutRootScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingBottom="100dp"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:background="@android:color/transparent">

    <LinearLayout
        android:id="@+id/workoutRoot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="32dp"
        android:paddingHorizontal="24dp"
        android:paddingBottom="48dp">

        <!-- Header Section -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="bottom">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WORKOUT "
                android:textColor="@color/white"
                android:textSize="28sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="-0.02" />

            <TextView
                android:id="@+id/tvWorkoutHeaderSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACTIVITY"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="-0.02" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvWorkoutHeaderDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="24dp"
            android:text="TRACK YOUR GYM PROGRESS &amp; WORKOUT LOGS"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.15"
            android:alpha="0.4"
            android:textAllCaps="true" />

        <!-- STATS PANEL (Row of 3 glassmorphic cards) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp"
            android:weightSum="3">

            <!-- Active Minutes Card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="16dp"
                android:gravity="center"
                android:background="@drawable/bg_search_modern"
                android:layout_marginEnd="8dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_clock"
                    android:tag="theme_tint"
                    android:layout_marginBottom="8dp"
                    app:tint="#FFFFFF" />

                <TextView
                    android:id="@+id/tvWorkoutStatMinutes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="45"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:fontFamily="sans-serif-black" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Min Active"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-medium"
                    android:alpha="0.7" />
            </LinearLayout>

            <!-- Exercises Completed Card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="16dp"
                android:gravity="center"
                android:background="@drawable/bg_search_modern"
                android:layout_marginHorizontal="4dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_dumbbell"
                    android:tag="theme_tint"
                    android:layout_marginBottom="8dp"
                    app:tint="#FFFFFF" />

                <TextView
                    android:id="@+id/tvWorkoutStatCompleted"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:fontFamily="sans-serif-black" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Logged"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-medium"
                    android:alpha="0.7"
                    android:gravity="center" />
            </LinearLayout>

            <!-- Calories Burned Card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="16dp"
                android:gravity="center"
                android:background="@drawable/bg_search_modern"
                android:layout_marginStart="8dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_receipt"
                    android:tag="theme_tint"
                    android:layout_marginBottom="8dp"
                    app:tint="#FFFFFF" />

                <TextView
                    android:id="@+id/tvWorkoutStatCalories"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="350"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:fontFamily="sans-serif-black" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kcal Burned"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-medium"
                    android:alpha="0.7" />
            </LinearLayout>
        </LinearLayout>

        <!-- TODAY'S ROUTINE CARD -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardTodayRoutine"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="#1AFFFFFF"
            app:cardBackgroundColor="#0DFFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TODAY'S WORKOUT TARGET"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-black"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvRoutineFocus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Upper Body Push Split"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="16dp" />

                <!-- Exercises Checklist -->
                <CheckBox
                    android:id="@+id/chkExercise1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Dumbbell Bench Press (4 sets x 10 reps)"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="8dp" />

                <CheckBox
                    android:id="@+id/chkExercise2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Incline Dumbbell Fly (3 sets x 12 reps)"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="8dp" />

                <CheckBox
                    android:id="@+id/chkExercise3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Seated Shoulder Overhead Press (4 sets x 10 reps)"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="8dp" />

                <CheckBox
                    android:id="@+id/chkExercise4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Cable Tricep Pushdown (3 sets x 15 reps)"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLogRoutine"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="COMPLETE &amp; LOG SESSION"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.05"
                    app:backgroundTint="#FFFFFF"
                    app:cornerRadius="26dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ADD CUSTOM EXERCISE CARD -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAddCustom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="#1AFFFFFF"
            app:cardBackgroundColor="#0DFFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LOG CUSTOM EXERCISE"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-black"
                    android:layout_marginBottom="16dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColorHint="@color/text_secondary"
                    android:layout_marginBottom="12dp"
                    app:hintTextColor="#FFFFFF"
                    app:boxStrokeColor="#FFFFFF"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etExerciseName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Exercise Name (e.g. Bicep Curl)"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:inputType="text" />
                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:layout_marginBottom="16dp">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColorHint="@color/text_secondary"
                        android:layout_marginEnd="6dp"
                        app:hintTextColor="#FFFFFF"
                        app:boxStrokeColor="#FFFFFF"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etSets"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Sets (e.g. 3)"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:inputType="number" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColorHint="@color/text_secondary"
                        android:layout_marginStart="6dp"
                        app:hintTextColor="#FFFFFF"
                        app:boxStrokeColor="#FFFFFF"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etReps"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Reps (e.g. 12)"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:inputType="number" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAddCustomLog"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="ADD EXERCISE LOG"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.05"
                    app:backgroundTint="#FFFFFF"
                    app:cornerRadius="26dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
