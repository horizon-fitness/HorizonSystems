<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:paddingTop="28dp"
    android:paddingHorizontal="0dp"
    android:clipToPadding="false">

    <!-- Handle Bar -->
    <View
        android:layout_width="48dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="28dp"
        android:background="#33FFFFFF" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="28dp">

        <TextView
            android:id="@+id/sheetTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EDIT MEMBER PROFILE"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:fontFamily="sans-serif-black"
            android:textStyle="bold|italic"
            android:textAllCaps="true"
            android:letterSpacing="-0.02" />

        <TextView
            android:id="@+id/sheetSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="ELITE IDENTITY MANAGEMENT"
            android:textColor="#A855F7"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:letterSpacing="0.2"
            android:layout_marginBottom="24dp" />
    </LinearLayout>

    <!-- Sliding Tabs -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayoutProfile"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:tabMode="scrollable"
        app:tabIndicatorHeight="3dp"
        app:tabIndicatorColor="#A855F7"
        app:tabSelectedTextColor="#FFFFFF"
        app:tabTextColor="#80FFFFFF"
        app:tabRippleColor="@android:color/transparent"
        app:tabTextAppearance="@style/TabTextAppearance"
        app:tabIndicatorFullWidth="false" />

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPagerProfile"
        android:layout_width="match_parent"
        android:layout_height="450dp" />

    <!-- Fixed Footer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp"
        android:background="#0DFFFFFF">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveChanges"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="SAVE FULL PROFILE"
            android:textColor="@color/white"
            android:textSize="11sp"
            android:textStyle="bold|italic"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            app:cornerRadius="16dp"
            app:backgroundTint="#A855F7"
            app:icon="@drawable/ic_check_circle"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            android:layout_marginBottom="8dp" />

        <ProgressBar
            android:id="@+id/pbSaving"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelEdit"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="DISCARD CHANGES"
            android:textColor="#EF4444"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
