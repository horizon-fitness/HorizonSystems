<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:fillViewport="true"
    android:scrollbars="none">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="100dp"
        android:paddingTop="24dp">

        <LinearLayout
            android:id="@+id/headerContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:orientation="horizontal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TRAINING "
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold|italic"
                android:fontFamily="sans-serif-black" />

            <TextView
                android:id="@+id/tv_booking_theme_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SCHEDULE"
                android:textColor="#A855F7"
                android:textSize="24sp"
                android:textStyle="bold|italic"
                android:fontFamily="sans-serif-black" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_book_and_pay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="BOOK &amp; MANAGE YOUR NEXT SESSION"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:alpha="0.8"
            app:layout_constraintStart_toStartOf="@+id/headerContainer"
            app:layout_constraintTop_toBottomOf="@+id/headerContainer" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_quick_book"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="24dp"
            android:text="BOOK YOUR SESSION"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            app:backgroundTint="#A855F7"
            app:cornerRadius="20dp"
            app:icon="@drawable/ic_calendar"
            app:iconPadding="12dp"
            app:iconGravity="textStart"
            app:layout_constraintTop_toBottomOf="@+id/tv_book_and_pay" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/calendar_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="20dp"
            app:cardBackgroundColor="#0DFFFFFF"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeColor="#1AFFFFFF"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@+id/btn_quick_book">

            <CalendarView
                android:id="@+id/calendar_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:theme="@style/Theme.MaterialComponents" />

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cv_date_details"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="#A855F7"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@+id/calendar_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tv_selected_date_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SELECTED DATE INFO"
                    android:textColor="#E9D5FF"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tv_selected_date_info"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Select a date to see session logs"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif-medium"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tv_active_training_logs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="32dp"
            android:text="Upcoming Sessions"
            android:textColor="@color/white"
            android:alpha="0.4"
            android:textSize="11sp"
            android:fontFamily="sans-serif-black"
            android:textAllCaps="true"
            android:letterSpacing="0.2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/cv_date_details" />

        <LinearLayout
            android:id="@+id/filter_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="24dp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@+id/tv_active_training_logs">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_filter_all"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="All"
                android:textSize="11sp"
                android:textStyle="bold"
                android:backgroundTint="#A855F7"
                android:textColor="@color/white"
                android:layout_marginEnd="8dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:cornerRadius="18dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_filter_pending"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Pending"
                android:textSize="11sp"
                android:textStyle="bold"
                android:backgroundTint="#0DFFFFFF"
                android:textColor="@color/text_secondary"
                android:layout_marginEnd="8dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:cornerRadius="18dp"
                app:strokeColor="#1AFFFFFF"
                app:strokeWidth="1dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_filter_approved"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Approved"
                android:textSize="11sp"
                android:textStyle="bold"
                android:backgroundTint="#0DFFFFFF"
                android:textColor="@color/text_secondary"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:cornerRadius="18dp"
                app:strokeColor="#1AFFFFFF"
                app:strokeWidth="1dp"/>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Pagination (Integrated) -->
            <LinearLayout
                android:id="@+id/pagination_container_booking"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:visibility="gone">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_prev_booking"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:insetLeft="0dp"
                    android:insetTop="0dp"
                    android:insetRight="0dp"
                    android:insetBottom="0dp"
                    android:padding="0dp"
                    app:icon="@drawable/ic_chevron_left"
                    app:iconTint="#BC8CF2"
                    app:iconSize="16dp"
                    app:iconGravity="textStart" />

                <TextView
                    android:id="@+id/tv_page_number_booking"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="6dp"
                    android:text="1/1"
                    android:textColor="@color/white"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:alpha="0.5" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_next_booking"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:insetLeft="0dp"
                    android:insetTop="0dp"
                    android:insetRight="0dp"
                    android:insetBottom="0dp"
                    android:padding="0dp"
                    app:icon="@drawable/ic_chevron_right"
                    app:iconTint="#BC8CF2"
                    app:iconSize="16dp"
                    app:iconGravity="textStart" />
            </LinearLayout>
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvTrainingLogs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:paddingHorizontal="24dp"
            android:paddingBottom="24dp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@+id/filter_container" />

        <LinearLayout
            android:id="@+id/emptyStateContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@+id/filter_container">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_clock"
                app:tint="@color/white"
                android:alpha="0.2" />

            <TextView
                android:id="@+id/bookingEmptyState"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="No upcoming sessions found."
                android:textColor="@color/white"
                android:textSize="13sp"
                android:alpha="0.4"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>
