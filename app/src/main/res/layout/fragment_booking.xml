<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0a090d"
    android:fillViewport="true"
    android:scrollbars="none">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="100dp"
        android:paddingTop="24dp">

        <LinearLayout
            android:id="@+id/headerContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:orientation="horizontal"
            android:gravity="bottom"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tv_training_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TRAINING "
                android:textColor="@color/white"
                android:textSize="28sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="-0.02" />

            <TextView
                android:id="@+id/tv_booking_theme_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SCHEDULE"
                android:textColor="#A855F7"
                android:textSize="28sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="-0.02" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_book_and_pay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="BOOK &amp; MANAGE YOUR NEXT SESSION"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.15"
            android:alpha="0.4"
            app:layout_constraintStart_toStartOf="@+id/headerContainer"
            app:layout_constraintTop_toBottomOf="@+id/headerContainer" />

        <LinearLayout
            android:id="@+id/booking_actions_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="28dp"
            android:orientation="horizontal"
            android:weightSum="1"
            app:layout_constraintTop_toBottomOf="@+id/tv_book_and_pay">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_quick_book"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:tag="no_theme_override"
                android:layout_width="match_parent"
                android:layout_height="62dp"
                android:text="BOOKING"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.05"
                android:backgroundTint="@android:color/transparent"
                app:strokeColor="#A855F7"
                app:strokeWidth="1.5dp"
                app:cornerRadius="31dp"
                app:icon="@drawable/ic_calendar"
                app:iconPadding="8dp"
                app:iconGravity="textStart"
                app:iconSize="16dp"
                app:iconTint="#A855F7" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/calendar_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="20dp"
            app:cardBackgroundColor="#0DFFFFFF"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeColor="#1AFFFFFF"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@+id/booking_actions_container">

            <CalendarView
                android:id="@+id/calendar_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:theme="@style/CustomCalendarViewTheme" />

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cv_date_details"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="#0DFFFFFF"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="#1AFFFFFF"
            app:strokeWidth="1dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@+id/calendar_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tv_selected_date_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SELECTED DATE INFO"
                    android:textColor="#E9D5FF"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tv_selected_date_info"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Select a date to see session logs"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif-medium"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:id="@+id/training_logs_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="32dp"
            android:orientation="horizontal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/cv_date_details">

            <TextView
                android:id="@+id/tv_upcoming_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="-0.02"
                android:text="UPCOMING "
                android:textColor="@color/white"
                android:textSize="22sp" />

            <TextView
                android:id="@+id/tv_upcoming_sessions_accent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="-0.02"
                android:text="SESSIONS"
                android:textColor="#A855F7"
                android:textSize="22sp" />
        </LinearLayout>

        <!-- Labs Search Header for Upcoming Sessions -->
        <LinearLayout
            android:id="@+id/labs_search_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@+id/training_logs_header">

            <LinearLayout
                android:id="@+id/containerSearchBooking"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/bg_search_modern"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_search"
                    app:tint="@color/text_secondary"
                    android:alpha="0.4" />

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etSearchBooking"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:hint="Search sessions..."
                    android:textColor="@color/white"
                    android:textColorHint="#4DFFFFFF"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:paddingStart="8dp"
                    android:inputType="text"
                    android:imeOptions="actionSearch" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnSortBooking"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_action_icon"
                android:src="@drawable/ic_sort"
                app:tint="@color/white"
                android:padding="12dp"
                android:scaleType="centerInside" />

            <ImageButton
                android:id="@+id/btnFilterBooking"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_action_icon"
                android:src="@drawable/ic_tune"
                app:tint="@color/white"
                android:padding="12dp"
                android:scaleType="centerInside" />
        </LinearLayout>

        <!-- Pagination -->
        <LinearLayout
            android:id="@+id/pagination_container_booking"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="24dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/labs_search_header">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_prev_booking"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:padding="0dp"
                app:icon="@drawable/ic_chevron_left"
                app:iconGravity="textStart"
                app:iconSize="16dp"
                app:iconTint="#A855F7" />

            <TextView
                android:id="@+id/tv_page_number_booking"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="6dp"
                android:alpha="0.5"
                android:fontFamily="sans-serif-black"
                android:text="1/1"
                android:textColor="@color/white"
                android:textSize="10sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_next_booking"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:padding="0dp"
                app:icon="@drawable/ic_chevron_right"
                app:iconGravity="textStart"
                app:iconSize="16dp"
                app:iconTint="#A855F7" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="#1AFFFFFF"
            android:layout_marginHorizontal="24dp"
            android:layout_marginBottom="12dp"
            app:layout_constraintTop_toBottomOf="@+id/labs_search_header" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvTrainingLogs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:layout_marginHorizontal="24dp"
            android:paddingTop="8dp"
            android:paddingBottom="40dp"
            app:layout_constraintTop_toBottomOf="@+id/labs_search_header" />


        <LinearLayout
            android:id="@+id/emptyStateContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@+id/labs_search_header">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_clock"
                app:tint="@color/white"
                android:alpha="0.2" />

            <TextView
                android:id="@+id/bookingEmptyState"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="No upcoming sessions found."
                android:textColor="@color/white"
                android:textSize="13sp"
                android:alpha="0.4"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>
