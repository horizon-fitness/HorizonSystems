<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/landing_background"
    android:fitsSystemWindows="true">

    <!-- Premium Ambient Glow -->
    <View
        android:layout_width="500dp"
        android:layout_height="500dp"
        android:alpha="0.15"
        android:background="@drawable/ambient_glow"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginEnd="-250dp"
        android:layout_marginTop="-200dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/innerLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingHorizontal="32dp"
            android:paddingTop="48dp"
            android:paddingBottom="40dp"
            android:gravity="center_horizontal">

            <!-- Back Button -->
            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_back_arrow"
                android:layout_marginStart="-12dp"
                android:layout_gravity="start"
                app:tint="@color/white"
                android:contentDescription="Back" />

            <!-- Header -->
            <TextView
                android:id="@+id/forgotTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Account Recovery"
                android:textColor="@color/white"
                android:textSize="32sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="-0.02" />

            <TextView
                android:id="@+id/stepIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Step 1 of 3"
                android:textColor="@color/landing_primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:alpha="0.6"
                android:letterSpacing="0.1" />

            <!-- Step 1: Email Entry -->
            <LinearLayout
                android:id="@+id/layoutStepEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="48dp"
                android:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:layout_gravity="center_horizontal"
                    android:text="ENTER REGISTERED EMAIL"
                    android:textColor="#80FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:gravity="center" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="62dp" android:background="@drawable/input_field_bg" android:gravity="center_vertical" android:paddingHorizontal="20dp">
                    <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@android:drawable/ic_dialog_email" app:tint="#80FFFFFF" />
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/recoveryEmailEdit" android:layout_width="match_parent" android:layout_height="match_parent" android:layout_marginStart="16dp" android:background="@null" android:hint="email@example.com" android:inputType="textEmailAddress" android:textColor="@color/white" android:textColorHint="#40FFFFFF" android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Step 2: PIN Verification -->
            <LinearLayout
                android:id="@+id/layoutStepOTP"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="48dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:layout_gravity="center_horizontal"
                    android:text="ENTER 6-DIGIT RESET PIN"
                    android:textColor="#80FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:gravity="center" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">
                    <EditText android:id="@+id/otp1" android:layout_width="46dp" android:layout_height="54dp" android:background="@drawable/otp_box_bg" android:gravity="center" android:inputType="number" android:maxLength="1" android:textColor="@color/white" android:textSize="20sp" android:textStyle="bold" android:layout_marginHorizontal="3dp" android:cursorVisible="false" />
                    <EditText android:id="@+id/otp2" android:layout_width="46dp" android:layout_height="54dp" android:background="@drawable/otp_box_bg" android:gravity="center" android:inputType="number" android:maxLength="1" android:textColor="@color/white" android:textSize="20sp" android:textStyle="bold" android:layout_marginHorizontal="3dp" android:cursorVisible="false" />
                    <EditText android:id="@+id/otp3" android:layout_width="46dp" android:layout_height="54dp" android:background="@drawable/otp_box_bg" android:gravity="center" android:inputType="number" android:maxLength="1" android:textColor="@color/white" android:textSize="20sp" android:textStyle="bold" android:layout_marginHorizontal="3dp" android:cursorVisible="false" />
                    <EditText android:id="@+id/otp4" android:layout_width="46dp" android:layout_height="54dp" android:background="@drawable/otp_box_bg" android:gravity="center" android:inputType="number" android:maxLength="1" android:textColor="@color/white" android:textSize="20sp" android:textStyle="bold" android:layout_marginHorizontal="3dp" android:cursorVisible="false" />
                    <EditText android:id="@+id/otp5" android:layout_width="46dp" android:layout_height="54dp" android:background="@drawable/otp_box_bg" android:gravity="center" android:inputType="number" android:maxLength="1" android:textColor="@color/white" android:textSize="20sp" android:textStyle="bold" android:layout_marginHorizontal="3dp" android:cursorVisible="false" />
                    <EditText android:id="@+id/otp6" android:layout_width="46dp" android:layout_height="54dp" android:background="@drawable/otp_box_bg" android:gravity="center" android:inputType="number" android:maxLength="1" android:textColor="@color/white" android:textSize="20sp" android:textStyle="bold" android:layout_marginHorizontal="3dp" android:cursorVisible="false" />
                </LinearLayout>
            </LinearLayout>

            <!-- Step 3: New Password -->
            <LinearLayout
                android:id="@+id/layoutStepReset"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="48dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:layout_gravity="center_horizontal"
                    android:text="CREATE NEW PASSWORD"
                    android:textColor="#80FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:gravity="center" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="62dp" android:background="@drawable/input_field_bg" android:gravity="center_vertical" android:paddingHorizontal="20dp" android:layout_marginBottom="12dp">
                    <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@android:drawable/ic_lock_idle_lock" app:tint="#80FFFFFF" />
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/newPassEdit" android:layout_width="match_parent" android:layout_height="match_parent" android:layout_marginStart="16dp" android:background="@null" android:hint="New Password" android:inputType="textPassword" android:textColor="@color/white" android:textColorHint="#40FFFFFF" android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="62dp" android:background="@drawable/input_field_bg" android:gravity="center_vertical" android:paddingHorizontal="20dp">
                    <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@android:drawable/ic_lock_idle_lock" app:tint="#80FFFFFF" />
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/confirmNewPassEdit" android:layout_width="match_parent" android:layout_height="match_parent" android:layout_marginStart="16dp" android:background="@null" android:hint="Confirm New Password" android:inputType="textPassword" android:textColor="@color/white" android:textColorHint="#40FFFFFF" android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Navigation Buttons -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="60dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnNext"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="Next Step"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    app:backgroundTint="@null"
                    android:background="@drawable/button_premium"
                    android:visibility="visible" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnResetPass"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="Reset Password"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    app:backgroundTint="@null"
                    android:background="@drawable/button_premium"
                    android:visibility="gone" />
            </RelativeLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
