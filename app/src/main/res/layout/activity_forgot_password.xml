<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayout"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/landing_background"
    android:fitsSystemWindows="true">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/innerLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingHorizontal="32dp"
            android:paddingTop="40dp"
            android:paddingBottom="40dp"
            android:gravity="center_horizontal">

            <!-- Back Button -->
            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_back_arrow"
                android:layout_marginStart="-12dp"
                android:layout_gravity="start"
                app:tint="@color/white"
                android:contentDescription="Back" />

            <!-- Gym Logo Header (Shown if connected) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/gymLogoContainer"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginTop="8dp"
                android:visibility="gone"
                app:cardBackgroundColor="#1AFFFFFF"
                app:cardCornerRadius="40dp"
                app:cardElevation="0dp">
                <ImageView
                    android:id="@+id/forgotGymLogo"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/horizon_logo"
                    android:scaleType="centerInside" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Header -->
            <TextView
                android:id="@+id/forgotTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Account Recovery"
                android:textColor="@color/white"
                android:textSize="36sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="-0.02" />

            <TextView
                android:id="@+id/forgotSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="We'll help you get back into your account."
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:alpha="0.8" />

            <!-- Progress Indicator -->
            <TextView
                android:id="@+id/stepIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Step 1 of 3: Identity Verification"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:fontFamily="sans-serif-black" />

            <!-- Step 1: Email Entry -->
            <LinearLayout
                android:id="@+id/layoutStepEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="60dp"
                android:visibility="visible">


 
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gym/Tenant Code:"
                    android:textColor="#CCFFFFFF"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp"
                    android:layout_gravity="start"
                    android:fontFamily="sans-serif-medium"
                    android:id="@+id/lblGymCode"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/tenantCodeResetLayout"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/input_field_bg"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="20dp"
                    android:visibility="gone">
                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@drawable/ic_qr_code"
                        app:tint="#80FFFFFF" />
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/tenantCodeResetEdit"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginStart="16dp"
                        android:background="@null"
                        android:hint="Gym Code (e.g. COR-9213)"
                        android:inputType="textCapCharacters"
                        android:textColor="@color/white"
                        android:textColorHint="#40FFFFFF"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Registered Email Address:"
                    android:textColor="#CCFFFFFF"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp"
                    android:layout_gravity="start"
                    android:fontFamily="sans-serif-medium" />
                <LinearLayout
                    android:id="@+id/recoveryEmailLayout"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/input_field_bg"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="20dp">
                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@android:drawable/ic_dialog_email"
                        app:tint="#80FFFFFF" />
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/recoveryEmailEdit"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginStart="16dp"
                        android:background="@null"
                        android:hint="Registered Email"
                        android:inputType="textEmailAddress"
                        android:textColor="@color/white"
                        android:textColorHint="#40FFFFFF"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>
            </LinearLayout>

            <!-- Step 2: PIN Verification -->
            <LinearLayout
                android:id="@+id/layoutStepOTP"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="60dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:layout_gravity="center_horizontal"
                    android:text="PIN VERIFICATION"
                    android:textColor="#80FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">
                    <EditText android:id="@+id/otp1" android:layout_width="48dp" android:layout_height="64dp" android:background="@drawable/otp_box_bg" android:gravity="center" android:inputType="number" android:maxLength="1" android:textColor="@color/white" android:textSize="22sp" android:textStyle="bold" android:layout_marginHorizontal="4dp" android:cursorVisible="false" />
                    <EditText android:id="@+id/otp2" android:layout_width="48dp" android:layout_height="64dp" android:background="@drawable/otp_box_bg" android:gravity="center" android:inputType="number" android:maxLength="1" android:textColor="@color/white" android:textSize="22sp" android:textStyle="bold" android:layout_marginHorizontal="4dp" android:cursorVisible="false" />
                    <EditText android:id="@+id/otp3" android:layout_width="48dp" android:layout_height="64dp" android:background="@drawable/otp_box_bg" android:gravity="center" android:inputType="number" android:maxLength="1" android:textColor="@color/white" android:textSize="22sp" android:textStyle="bold" android:layout_marginHorizontal="4dp" android:cursorVisible="false" />
                    <EditText android:id="@+id/otp4" android:layout_width="48dp" android:layout_height="64dp" android:background="@drawable/otp_box_bg" android:gravity="center" android:inputType="number" android:maxLength="1" android:textColor="@color/white" android:textSize="22sp" android:textStyle="bold" android:layout_marginHorizontal="4dp" android:cursorVisible="false" />
                    <EditText android:id="@+id/otp5" android:layout_width="48dp" android:layout_height="64dp" android:background="@drawable/otp_box_bg" android:gravity="center" android:inputType="number" android:maxLength="1" android:textColor="@color/white" android:textSize="22sp" android:textStyle="bold" android:layout_marginHorizontal="4dp" android:cursorVisible="false" />
                    <EditText android:id="@+id/otp6" android:layout_width="48dp" android:layout_height="64dp" android:background="@drawable/otp_box_bg" android:gravity="center" android:inputType="number" android:maxLength="1" android:textColor="@color/white" android:textSize="22sp" android:textStyle="bold" android:layout_marginHorizontal="4dp" android:cursorVisible="false" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="32dp"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/txtResendLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Didn't receive code?"
                        android:textColor="#80FFFFFF"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/btnResendOtp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Resend"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:clickable="false"
                        android:alpha="0.3" />
                </LinearLayout>

                <TextView
                    android:id="@+id/txtResendTimer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="8dp"
                    android:text="You can resend in 60s"
                    android:textColor="#40FFFFFF"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Step 3: New Password -->
            <LinearLayout
                android:id="@+id/layoutStepReset"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="60dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:layout_gravity="center_horizontal"
                    android:text="SECURE YOUR ACCOUNT"
                    android:textColor="#80FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />
 
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="New Password:"
                    android:textColor="#CCFFFFFF"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp"
                    android:layout_gravity="start"
                    android:fontFamily="sans-serif-medium" />

                <LinearLayout
                    android:id="@+id/newPassLayout"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/input_field_bg"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="20dp">
                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@android:drawable/ic_lock_idle_lock"
                        app:tint="#80FFFFFF" />
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/newPassEdit"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:background="@null"
                        android:hint="New Password"
                        android:inputType="textPassword"
                        android:textColor="@color/white"
                        android:textColorHint="#40FFFFFF"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" />
                    <ImageView
                        android:id="@+id/btnToggleNewPass"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@android:drawable/ic_menu_view"
                        android:alpha="0.5"
                        app:tint="#80FFFFFF"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Confirm New Password:"
                    android:textColor="#CCFFFFFF"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp"
                    android:layout_gravity="start"
                    android:fontFamily="sans-serif-medium" />
                <LinearLayout
                    android:id="@+id/confirmNewPassLayout"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/input_field_bg"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="20dp">
                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@android:drawable/ic_lock_idle_lock"
                        app:tint="#80FFFFFF" />
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/confirmNewPassEdit"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:background="@null"
                        android:hint="Confirm New Password"
                        android:inputType="textPassword"
                        android:textColor="@color/white"
                        android:textColorHint="#40FFFFFF"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" />
                    <ImageView
                        android:id="@+id/btnToggleConfirmPass"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@android:drawable/ic_menu_view"
                        android:alpha="0.5"
                        app:tint="#80FFFFFF"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>
            </LinearLayout>

            <!-- Navigation Buttons -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="60dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnNext"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:text="Next Step"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    app:backgroundTint="@null"
                    android:background="@drawable/button_premium"
                    android:fontFamily="sans-serif-black"
                    android:visibility="visible" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnResetPass"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:text="Reset Password"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    app:backgroundTint="@null"
                    android:background="@drawable/button_premium"
                    android:fontFamily="sans-serif-black"
                    android:visibility="gone" />
            </RelativeLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
