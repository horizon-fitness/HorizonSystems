<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingBottom="100dp"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:background="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="32dp"
        android:paddingHorizontal="24dp"
        android:paddingBottom="48dp">

        <!-- Header Section -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="bottom">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HEALTH &amp; "
                android:textColor="@color/white"
                android:textSize="28sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="-0.02" />

            <TextView
                android:id="@+id/tvBmiHeaderSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VITALITY"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="-0.02" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvBmiHeaderDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="24dp"
            android:text="PERSONAL BMI &amp; BODY METRICS"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.15"
            android:alpha="0.4"
            android:textAllCaps="true" />

        <!-- BODY COMPOSITION & BMI SUITE -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/bg_search_modern">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BODY COMPOSITION &amp; BMI"
                    android:textColor="#80FFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.05" />

                <TextView
                    android:id="@+id/tvBmiStatusLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="NORMAL"
                    android:textColor="#10B981"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-black"
                    android:background="@drawable/bg_status_tag"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp" />
            </RelativeLayout>

            <!-- Large BMI Display -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="bottom"
                android:layout_marginBottom="16dp">
                <TextView
                    android:id="@+id/tvBmiValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="22.4"
                    android:textColor="@color/white"
                    android:textSize="48sp"
                    android:fontFamily="sans-serif-black"
                    android:textStyle="bold"
                    android:includeFontPadding="false" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" kg/m²"
                    android:textColor="#80FFFFFF"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginStart="4dp"
                    android:layout_marginBottom="8dp" />
            </LinearLayout>

            <!-- Health Details Grid -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3"
                android:layout_marginBottom="12dp">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Height"
                        android:textColor="#60FFFFFF"
                        android:textSize="12sp" />
                    <TextView
                        android:id="@+id/tvBmiHeight"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="175 cm"
                        android:textColor="@color/white"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Weight"
                        android:textColor="#60FFFFFF"
                        android:textSize="12sp" />
                    <TextView
                        android:id="@+id/tvBmiWeight"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="68.5 kg"
                        android:textColor="@color/white"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ideal Range"
                        android:textColor="#60FFFFFF"
                        android:textSize="12sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="18.5 - 24.9"
                        android:textColor="@color/white"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="#15FFFFFF"
                android:layout_marginVertical="10dp" />

            <TextView
                android:id="@+id/tvBmiAdvice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Excellent! You have a healthy weight. Keep up your regular gym workouts and consistent nutrition plan."
                android:textColor="#CCFFFFFF"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginBottom="20dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#15FFFFFF"
                android:layout_marginVertical="10dp" />

            <!-- BMI Stats Input -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="UPDATE YOUR BODY METRICS:"
                android:textColor="#80FFFFFF"
                android:textSize="11sp"
                android:fontFamily="sans-serif-bold"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Weight (kg):"
                android:textColor="#B0FFFFFF"
                android:textSize="12sp"
                android:layout_marginBottom="4dp" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/input_field_bg"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="12dp">
                <EditText
                    android:id="@+id/etCalcWeight"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:hint="e.g. 68.5"
                    android:inputType="numberDecimal"
                    android:textColor="@color/white"
                    android:textColorHint="#40FFFFFF"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Height (cm):"
                android:textColor="#B0FFFFFF"
                android:textSize="12sp"
                android:layout_marginBottom="4dp" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/input_field_bg"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="16dp">
                <EditText
                    android:id="@+id/etCalcHeight"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:hint="e.g. 175"
                    android:inputType="numberDecimal"
                    android:textColor="@color/white"
                    android:textColorHint="#40FFFFFF"
                    android:textSize="14sp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCalculateBmi"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Update Body Stats"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                app:backgroundTint="@null"
                android:background="@drawable/button_premium" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
