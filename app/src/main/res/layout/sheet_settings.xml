<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:padding="28dp">

    <!-- Handle Bar -->
    <View
        android:layout_width="48dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="28dp"
        android:background="#33FFFFFF" />

    <TextView
        android:id="@+id/sheetTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SETTINGS"
        android:textColor="@color/white"
        android:textSize="22sp"
        android:fontFamily="sans-serif-black"
        android:textStyle="bold|italic"
        android:textAllCaps="true"
        android:letterSpacing="-0.02" />

    <TextView
        android:id="@+id/sheetSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="ACCOUNT &amp; PREFERENCES"
        android:textColor="#A855F7"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textAllCaps="true"
        android:letterSpacing="0.2"
        android:layout_marginBottom="24dp" />

    <!-- Profile Item Button -->
    <LinearLayout
        android:id="@+id/btnSettingProfile"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_search_modern"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:id="@+id/iconProfile"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="9.5dp"
            android:src="@drawable/ic_profile"
            android:background="@drawable/bg_action_icon"
            app:tint="@color/white" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="My Profile"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="View and edit your personal details"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:alpha="0.7"
                android:fontFamily="sans-serif" />
        </LinearLayout>

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_chevron_right"
            app:tint="#60FFFFFF" />
    </LinearLayout>

    <!-- Transaction History Item Button -->
    <LinearLayout
        android:id="@+id/btnSettingTransactions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_search_modern"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:id="@+id/iconTransactions"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="9.5dp"
            android:src="@drawable/ic_receipt"
            android:background="@drawable/bg_action_icon"
            app:tint="@color/white" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Transaction History"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="View your receipts, invoices, and payments"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:alpha="0.7"
                android:fontFamily="sans-serif" />
        </LinearLayout>

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_chevron_right"
            app:tint="#60FFFFFF" />
    </LinearLayout>

    <!-- Membership Item Button -->
    <LinearLayout
        android:id="@+id/btnSettingMembership"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_search_modern"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:id="@+id/iconMembership"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="9.5dp"
            android:src="@drawable/ic_membership"
            android:background="@drawable/bg_action_icon"
            app:tint="@color/white" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="My Membership"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="View active plan, billing details, and limits"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:alpha="0.7"
                android:fontFamily="sans-serif" />
        </LinearLayout>

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_chevron_right"
            app:tint="#60FFFFFF" />
    </LinearLayout>

    <!-- Sign Out Item Button (Tuned Red Theme) -->
    <LinearLayout
        android:id="@+id/btnSettingLogout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_search_modern"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:id="@+id/iconLogout"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="9.5dp"
            android:src="@drawable/ic_logout"
            android:background="@drawable/bg_action_icon"
            app:tint="#EF4444" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sign Out"
                android:textColor="#EF4444"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Log out of your gym account securely"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:alpha="0.7"
                android:fontFamily="sans-serif" />
        </LinearLayout>

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_chevron_right"
            app:tint="#60EF4444" />
    </LinearLayout>
</LinearLayout>
