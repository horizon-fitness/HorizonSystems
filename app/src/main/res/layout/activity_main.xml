<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/landing_background">

    <!-- Premium Ambient Background Glow -->
    <View
        android:layout_width="500dp"
        android:layout_height="500dp"
        android:alpha="0.1"
        android:background="@drawable/ambient_glow"
        android:layout_gravity="top|end"
        android:layout_marginEnd="-250dp"
        android:layout_marginTop="-200dp" />

    <!-- Main Content Container -->
    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Floating Glassmorphic Pill Tab Navigation Bar -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_gravity="bottom"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="20dp"
        app:cardCornerRadius="30dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#CC121115"
        app:strokeColor="#1AFFFFFF"
        app:strokeWidth="1dp">

        <com.google.android.material.bottomnavigation.BottomNavigationView
            style="@style/Widget.App.BottomNavigationView"
            android:id="@+id/bottomNavigationView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            app:backgroundTint="@android:color/transparent"
            android:translationY="6dp"
            app:elevation="0dp"
            app:itemIconSize="24dp"
            app:itemIconTint="@color/nav_item_selector"
            app:paddingBottomSystemWindowInsets="false"
            app:paddingTopSystemWindowInsets="false"
            app:itemPaddingTop="0dp"
            app:itemPaddingBottom="0dp"
            app:labelVisibilityMode="unlabeled" />
    </com.google.android.material.card.MaterialCardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>