<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="28dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/headerResidence"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3. RESIDENTIAL ADDRESS"
            android:textColor="#A855F7"
            android:textSize="9sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:letterSpacing="0.15"
            android:layout_marginBottom="16dp" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Street Address Line"
            android:layout_marginBottom="12dp"
            app:boxStrokeColor="#A855F7"
            app:hintTextColor="#A855F7">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editAddressLine"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:inputType="textPostalAddress" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Barangay"
            android:layout_marginBottom="12dp"
            app:boxStrokeColor="#A855F7"
            app:hintTextColor="#A855F7">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editBarangay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="City / Municipality"
            android:layout_marginBottom="12dp"
            app:boxStrokeColor="#A855F7"
            app:hintTextColor="#A855F7">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editCity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Province"
            android:layout_marginBottom="12dp"
            app:boxStrokeColor="#A855F7"
            app:hintTextColor="#A855F7">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editProvince"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Region"
            android:layout_marginBottom="12dp"
            app:boxStrokeColor="#A855F7"
            app:hintTextColor="#A855F7">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editRegion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
