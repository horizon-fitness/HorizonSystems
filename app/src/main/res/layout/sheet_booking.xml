<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/surface_dark"
    android:padding="24dp"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Handle Bar -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"
            android:background="#33FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Schedule Your Session"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select your desired workout or training slot."
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:alpha="0.8"
            android:layout_marginBottom="32dp" />

        <!-- Service Picker -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SERVICE CATEGORY"
            android:textColor="#A855F7"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:boxStrokeColor="#A855F7"
            app:hintEnabled="false"
            android:textColorHint="#40FFFFFF">
            <AutoCompleteTextView
                android:id="@+id/bookService"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Select a gym service"
                android:textColor="@color/white"
                android:inputType="none" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Date Picker -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PREFERRED DATE"
            android:textColor="#A855F7"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:boxStrokeColor="#A855F7"
            app:hintEnabled="false">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/bookDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Pick a date"
                android:textColor="@color/white"
                android:focusable="false"
                android:clickable="true"
                android:drawableStart="@drawable/ic_calendar"
                android:drawablePadding="12dp"
                app:drawableTint="@color/text_secondary" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Time Picker -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="START TIME"
            android:textColor="#A855F7"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="40dp"
            app:boxStrokeColor="#A855F7"
            app:hintEnabled="false">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/bookTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Select time slot"
                android:textColor="@color/white"
                android:focusable="false"
                android:clickable="true"
                android:drawableStart="@drawable/ic_clock"
                android:drawablePadding="12dp"
                app:drawableTint="@color/text_secondary" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Submit Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubmitBooking"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="Confirm Booking"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:textStyle="bold"
            app:cornerRadius="16dp"
            app:backgroundTint="#A855F7"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelBooking"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Discard"
            android:textAllCaps="false"
            android:textColor="@color/text_secondary" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
