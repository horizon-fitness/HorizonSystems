<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootSheetContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:padding="28dp">

    <!-- Elite Handle Bar -->
    <View
        android:layout_width="48dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="28dp"
        android:background="#33FFFFFF" />

    <!-- Title Section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SESSION BOOKING"
        android:textColor="@color/white"
        android:textSize="22sp"
        android:fontFamily="sans-serif-black"
        android:letterSpacing="-0.02" />

    <TextView
        android:id="@+id/sheetSubTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="SELECT YOUR PREFERRED SCHEDULE"
        android:textColor="#A855F7"
        android:textSize="10sp"
        android:fontFamily="sans-serif-black"
        android:letterSpacing="0.2"
        android:alpha="0.8" />

    <!-- Schedule Card -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="SCHEDULE DETAILS"
        android:textColor="@color/text_secondary"
        android:textSize="9sp"
        android:fontFamily="sans-serif-black"
        android:letterSpacing="0.15" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:cardBackgroundColor="#0DFFFFFF"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:strokeColor="#1AFFFFFF"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Date -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:hintEnabled="false"
                app:boxStrokeWidth="0dp"
                app:boxStrokeWidthFocused="0dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/bookDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Select Date"
                    android:textColor="@color/white"
                    android:textColorHint="#9CA3AF"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:focusable="false"
                    android:textSize="14sp"
                    android:drawableStart="@drawable/ic_calendar"
                    android:drawablePadding="12dp"
                    android:background="@null"
                    app:drawableTint="#FFFFFF" />
            </com.google.android.material.textfield.TextInputLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#0DFFFFFF"
                android:layout_marginVertical="8dp" />

            <!-- Time & Duration -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:hintEnabled="false"
                    app:boxStrokeWidth="0dp"
                    app:boxStrokeWidthFocused="0dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/bookTime"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Pick Time"
                        android:textColor="@color/white"
                        android:textColorHint="#9CA3AF"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp"
                        android:focusable="false"
                        android:textSize="14sp"
                        android:drawableStart="@drawable/ic_clock"
                        android:drawablePadding="12dp"
                        android:background="@null"
                        app:drawableTint="#FFFFFF" />
                </com.google.android.material.textfield.TextInputLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="24dp"
                    android:background="#0DFFFFFF"
                    android:layout_gravity="center_vertical"
                    android:layout_marginHorizontal="8dp" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.2"
                    app:hintEnabled="false"
                    app:boxStrokeWidth="0dp"
                    app:boxStrokeWidthFocused="0dp">
                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                        android:id="@+id/bookDuration"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="1 Hour"
                        android:textColor="@color/white"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp"
                        android:textSize="14sp"
                        android:inputType="none"
                        android:background="@null" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Selection Card -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="TRAINING OPTIONS"
        android:textColor="@color/text_secondary"
        android:textSize="9sp"
        android:fontFamily="sans-serif-black"
        android:letterSpacing="0.15" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:cardBackgroundColor="#0DFFFFFF"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:strokeColor="#1AFFFFFF"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:hintEnabled="false"
                app:boxStrokeWidth="0dp"
                app:boxStrokeWidthFocused="0dp">
                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/bookService"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Select Session Type"
                    android:textColor="@color/white"
                    android:textColorHint="#9CA3AF"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:textSize="14sp"
                    android:inputType="none"
                    android:background="@null" />
            </com.google.android.material.textfield.TextInputLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#0DFFFFFF"
                android:layout_marginVertical="8dp" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:hintEnabled="false"
                app:boxStrokeWidth="0dp"
                app:boxStrokeWidthFocused="0dp">
                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/bookCoach"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="General Workout (Self-Train)"
                    android:textColor="@color/white"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:textSize="14sp"
                    android:inputType="none"
                    android:background="@null" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Pricing Summary -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardPriceSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        app:cardBackgroundColor="#0DFFFFFF"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:strokeColor="#1AFFFFFF"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">
            
            <TextView
                android:id="@+id/txtTotalPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₱1,500.00"
                android:textColor="@color/white"
                android:textSize="32sp"
                android:fontFamily="sans-serif-black" />
            
            <TextView
                android:id="@+id/txtCoachFeeInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="NO COACH FEE"
                android:textColor="#10B981"
                android:textSize="11sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.05" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSubmitBooking"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginTop="32dp"
        android:text="CONFIRM &amp; PROCEED"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:fontFamily="sans-serif-black"
        app:cornerRadius="32dp"
        app:backgroundTint="#A855F7" />

</LinearLayout>
