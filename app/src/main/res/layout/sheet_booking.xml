<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootSheetContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical">

    <!-- Elite Handle Bar (Fixed at top) -->
    <View
        android:layout_width="48dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="28dp"
        android:layout_marginBottom="16dp"
        android:background="#33FFFFFF" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingBottom="40dp">

            <!-- Title Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SESSION BOOKING"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="-0.02" />

            <TextView
                android:id="@+id/sheetSubTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="SELECT YOUR PREFERRED SCHEDULE"
                android:textColor="#A855F7"
                android:textSize="10sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.2"
                android:alpha="0.8" />

            <!-- Schedule Card -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="SCHEDULE DETAILS"
                android:textColor="@color/text_secondary"
                android:textSize="9sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.15" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#0DFFFFFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="#1AFFFFFF"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Date -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:hintEnabled="false"
                        app:boxStrokeWidth="0dp"
                        app:boxStrokeWidthFocused="0dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/bookDate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Select Date"
                            android:textColor="@color/white"
                            android:textColorHint="#9CA3AF"
                            android:paddingTop="12dp"
                            android:paddingBottom="12dp"
                            android:focusable="false"
                            android:textSize="14sp"
                            android:drawableStart="@drawable/ic_calendar"
                            android:drawablePadding="12dp"
                            android:background="@null"
                            app:drawableTint="#FFFFFF" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#0DFFFFFF"
                        android:layout_marginVertical="8dp" />

                    <!-- Time & Duration -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            app:hintEnabled="false"
                            app:boxStrokeWidth="0dp"
                            app:boxStrokeWidthFocused="0dp">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/bookTime"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Pick Time"
                                android:textColor="@color/white"
                                android:textColorHint="#9CA3AF"
                                android:paddingTop="12dp"
                                android:paddingBottom="12dp"
                                android:focusable="false"
                                android:textSize="14sp"
                                android:drawableStart="@drawable/ic_clock"
                                android:drawablePadding="12dp"
                                android:background="@null"
                                app:drawableTint="#FFFFFF" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="24dp"
                            android:background="#0DFFFFFF"
                            android:layout_gravity="center_vertical"
                            android:layout_marginHorizontal="8dp" />

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1.2"
                            app:hintEnabled="false"
                            app:boxStrokeWidth="0dp"
                            app:boxStrokeWidthFocused="0dp">
                            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                                android:id="@+id/bookDuration"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="1 Hour"
                                android:textColor="@color/white"
                                android:paddingTop="12dp"
                                android:paddingBottom="12dp"
                                android:textSize="14sp"
                                android:inputType="none"
                                android:background="@null" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Selection Card -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="TRAINING OPTIONS"
                android:textColor="@color/text_secondary"
                android:textSize="9sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.15" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#0DFFFFFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="#1AFFFFFF"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Session Type Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="20dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_dumbbell"
                            app:tint="#80FFFFFF"
                            android:alpha="1" />

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            app:hintEnabled="false"
                            app:boxStrokeWidth="0dp"
                            app:boxStrokeWidthFocused="0dp">
                            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                                android:id="@+id/bookService"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Select Session Type"
                                android:textColor="@color/white"
                                android:textColorHint="#60FFFFFF"
                                android:paddingTop="0dp"
                                android:paddingBottom="0dp"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-medium"
                                android:inputType="none"
                                android:background="@null" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="#0DFFFFFF"
                        android:layout_marginHorizontal="20dp" />

                    <LinearLayout
                        android:id="@+id/emptyStateServicesBooking"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="20dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:visibility="gone">

                        <ImageView
                            android:id="@+id/ivEmptyServicesBooking"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_clock"
                            android:alpha="0.2"
                            app:tint="@color/white" />

                        <TextView
                            android:id="@+id/tvNoServicesBooking"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="No service offered"
                            android:textColor="@color/white"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-black"
                            android:letterSpacing="0.05"
                            android:alpha="0.4"
                            android:gravity="center" />
                    </LinearLayout>

                    <!-- Coach Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="20dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_profile"
                            app:tint="#80FFFFFF" />

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            app:hintEnabled="false"
                            app:boxStrokeWidth="0dp"
                            app:boxStrokeWidthFocused="0dp">
                            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                                android:id="@+id/bookCoach"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Select Coach"
                                android:textColor="@color/white"
                                android:textColorHint="#60FFFFFF"
                                android:paddingTop="0dp"
                                android:paddingBottom="0dp"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-medium"
                                android:inputType="none"
                                android:background="@null" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Pricing Summary -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPriceSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                app:cardBackgroundColor="#0DFFFFFF"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="#1AFFFFFF"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">
                    
                    <TextView
                        android:id="@+id/txtTotalPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₱1,500.00"
                        android:textColor="@color/white"
                        android:textSize="32sp"
                        android:fontFamily="sans-serif-black" />
                    
                    <TextView
                        android:id="@+id/txtCoachFeeInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="NO COACH FEE"
                        android:textColor="#10B981"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.05" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Booking Terms -->
            <TextView
                android:id="@+id/tvBookingTermsHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="BOOKING TERMS &amp; CONDITIONS"
                android:textColor="#A855F7"
                android:textSize="9sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.2" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardBookingTerms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#05FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#0DFFFFFF"
                app:strokeWidth="1dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:text="1. ARRIVAL POLICY: Participants are required to arrive at the facility at least thirty (30) minutes prior to their scheduled session. Please be advised that late arrivals may result in a proportional reduction of training time.\n\n2. CANCELLATION &amp; REFUND POLICY: Session cancellations are strictly permitted only when initiated at least one (1) hour before the scheduled start time. Refunds are eligible exclusively for cancellations made within this mandatory window or on the day preceding the session. Rescheduling of sessions is strictly prohibited. To finalize a cancellation, an official email notification must be submitted; upon processing, a follow-up email will be issued to confirm the approval status.\n\n3. CODE OF CONDUCT: Maintenance of professional gym attire and high standards of personal hygiene is mandatory at all times. Participants must strictly adhere to all directives and instructions provided by the coaching staff and facility personnel.\n\n4. RELEASE OF LIABILITY: By booking this session, you acknowledge and accept that physical exercise involves inherent risks of injury. The participant assumes all associated risks and agrees to waive any claims regarding injuries sustained during the session."
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:lineSpacingExtra="5dp"
                    android:fontFamily="sans-serif-medium" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Agreement -->
            <CheckBox
                android:id="@+id/cbBookingAgreement"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="I have read and agree to the Booking Terms &amp; Conditions."
                android:textColor="#80FFFFFF"
                android:textSize="11sp"
                android:buttonTint="#80FFFFFF"
                android:paddingStart="12dp"
                android:fontFamily="sans-serif-medium" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSubmitBooking"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="32dp"
                android:text="CONFIRM &amp; PROCEED"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:fontFamily="sans-serif-black"
                android:enabled="false"
                android:alpha="0.3"
                app:cornerRadius="32dp"
                app:backgroundTint="#A855F7" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelBooking"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:text="CANCEL TRANSACTION"
                android:textColor="#EF4444"
                android:textSize="10sp"
                android:fontFamily="sans-serif-black"
                android:textAllCaps="true"
                android:letterSpacing="0.15"
                app:strokeColor="#EF4444"
                app:strokeWidth="1dp"
                app:cornerRadius="28dp"
                app:backgroundTint="@android:color/transparent" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
