<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:padding="28dp">

    <!-- Handle Bar -->
    <View
        android:layout_width="48dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="28dp"
        android:background="#33FFFFFF" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CHANGE PASSWORD"
        android:textColor="@color/white"
        android:textSize="22sp"
        android:fontFamily="sans-serif-black"
        android:textStyle="bold|italic"
        android:textAllCaps="true"
        android:letterSpacing="-0.02" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="ELITE SECURITY PROTOCOL"
        android:textColor="#A855F7"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textAllCaps="true"
        android:letterSpacing="0.2"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="VERIFY IDENTITY"
        android:textColor="#A855F7"
        android:textSize="9sp"
        android:textStyle="bold"
        android:textAllCaps="true"
        android:letterSpacing="0.15"
        android:layout_marginBottom="12dp" />

    <!-- Current Password -->
    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Current Password"
        android:layout_marginBottom="16dp"
        app:passwordToggleEnabled="true"
        app:boxStrokeColor="#A855F7"
        app:hintTextColor="#A855F7"
        app:passwordToggleTint="@color/text_secondary"
        android:textColorHint="#40FFFFFF">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editCurrentPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:inputType="textPassword" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CONFIGURE NEW CREDENTIALS"
        android:textColor="#A855F7"
        android:textSize="9sp"
        android:textStyle="bold"
        android:textAllCaps="true"
        android:letterSpacing="0.15"
        android:layout_marginBottom="12dp" />

    <!-- New Password -->
    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="New Password"
        android:layout_marginBottom="16dp"
        app:passwordToggleEnabled="true"
        app:boxStrokeColor="#A855F7"
        app:hintTextColor="#A855F7"
        app:passwordToggleTint="@color/text_secondary"
        android:textColorHint="#40FFFFFF">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editNewPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:inputType="textPassword" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Confirm New Password -->
    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Confirm New Password"
        android:layout_marginBottom="12dp"
        app:passwordToggleEnabled="true"
        app:boxStrokeColor="#A855F7"
        app:hintTextColor="#A855F7"
        app:passwordToggleTint="@color/text_secondary"
        android:textColorHint="#40FFFFFF">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editConfirmPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:inputType="textPassword" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Password Requirements -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="24dp"
        android:paddingStart="4dp">
        <TextView
            android:id="@+id/reqLen"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="• Minimum 8 characters"
            android:textColor="#40FFFFFF"
            android:textSize="10sp"
            android:fontFamily="sans-serif-medium" />
        <TextView
            android:id="@+id/reqNum"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="• At least 1 number"
            android:textColor="#40FFFFFF"
            android:textSize="10sp"
            android:layout_marginTop="2dp"
            android:fontFamily="sans-serif-medium" />
        <TextView
            android:id="@+id/reqSpecial"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="• At least 1 special character"
            android:textColor="#40FFFFFF"
            android:textSize="10sp"
            android:layout_marginTop="2dp"
            android:fontFamily="sans-serif-medium" />
        <TextView
            android:id="@+id/reqCaps"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="• At least 1 uppercase letter"
            android:textColor="#40FFFFFF"
            android:textSize="10sp"
            android:layout_marginTop="2dp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <!-- Progress Spinner (Hidden by default) -->
    <ProgressBar
        android:id="@+id/pbUpdating"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:visibility="gone"
        android:indeterminateTint="#A855F7"/>

    <!-- Update Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnUpdatePassword"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="UPDATE LOGIN PASSWORD"
        android:textColor="@color/white"
        android:textSize="11sp"
        android:textStyle="bold|italic"
        android:textAllCaps="true"
        android:letterSpacing="0.1"
        app:cornerRadius="16dp"
        app:backgroundTint="#A855F7"
        app:icon="@drawable/ic_check_circle"
        app:iconGravity="textStart"
        app:iconPadding="12dp"
        android:layout_marginBottom="12dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCancelPassword"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="CANCEL PROCESS"
        android:textColor="#EF4444"
        android:textSize="10sp"
        android:textStyle="bold"
        android:textAllCaps="true"
        android:letterSpacing="0.15"
        app:strokeColor="#EF4444"
        app:strokeWidth="1dp"
        app:cornerRadius="12dp"
        app:backgroundTint="@android:color/transparent"
        android:layout_marginBottom="20dp" />

</LinearLayout>
