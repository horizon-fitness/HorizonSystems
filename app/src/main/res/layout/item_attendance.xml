<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardBackgroundColor="#0D0D10"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="#1AFFFFFF">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Date Block (Left) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardDateBlock"
            android:layout_width="60dp"
            android:layout_height="60dp"
            app:cardBackgroundColor="#0DFFFFFF"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvAttendanceMonth"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OCT"
                    android:textColor="#FFFFFF"
                    android:alpha="1.0"
                    android:textSize="9sp"
                    android:fontFamily="sans-serif-black"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tvAttendanceDay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="16"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:fontFamily="sans-serif-black" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Attendance Info (Center) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:orientation="vertical"
            app:layout_constraintTop_toTopOf="@id/cardDateBlock"
            app:layout_constraintBottom_toBottomOf="@id/cardDateBlock"
            app:layout_constraintStart_toEndOf="@id/cardDateBlock"
            app:layout_constraintEnd_toStartOf="@id/layoutStatusInfo">

            <TextView
                android:id="@+id/tvGymName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Horizon Gym"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="-0.01" />

            <TextView
                android:id="@+id/tvAttendanceLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="GYM CHECK-IN"
                android:textColor="@color/white"
                android:alpha="0.4"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.05" />
        </LinearLayout>

        <!-- Status Block (Right) -->
        <LinearLayout
            android:id="@+id/layoutStatusInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end"
            app:layout_constraintTop_toTopOf="@id/cardDateBlock"
            app:layout_constraintBottom_toBottomOf="@id/cardDateBlock"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tvCheckInTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="09:30 AM"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="-0.01" />

            <TextView
                android:id="@+id/tvStatusBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="PRESENT"
                android:textColor="#34D399"
                android:textSize="10sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.05"
                android:textAllCaps="true" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
