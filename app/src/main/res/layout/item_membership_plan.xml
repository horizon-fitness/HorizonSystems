<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardPlan"
    android:layout_width="260dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="16dp"
    app:cardBackgroundColor="#0D0D10"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:strokeColor="#1AFFFFFF"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="340dp"
        android:padding="20dp">

        <!-- Badge -->
        <TextView
            android:id="@+id/tvPlanBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/badge_premium"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:text="POPULAR"
            android:textColor="@color/white"
            android:textSize="9sp"
            android:textStyle="bold"
            android:letterSpacing="0.2"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Header -->
        <LinearLayout
            android:id="@+id/layoutPlanHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <TextView
                android:id="@+id/tvPlanName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MONTHLY PASS"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:fontFamily="sans-serif-black"
                android:textStyle="bold|italic"
                android:textAllCaps="true"
                android:letterSpacing="-0.02" />

            <TextView
                android:id="@+id/tvBillingCycle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="MONTHLY Billing"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.15" />
        </LinearLayout>

        <!-- Price -->
        <LinearLayout
            android:id="@+id/layoutPlanPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal"
            android:gravity="bottom"
            app:layout_constraintTop_toBottomOf="@id/layoutPlanHeader"
            app:layout_constraintStart_toStartOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₱"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:fontFamily="sans-serif-black"
                android:textStyle="bold|italic"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tvPlanPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1,500"
                android:textColor="@color/white"
                android:textSize="38sp"
                android:fontFamily="sans-serif-black"
                android:textStyle="bold|italic" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="10dp"
                android:text="/ Term"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.1" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:id="@+id/planDivider"
            android:layout_width="24dp"
            android:layout_height="3dp"
            android:layout_marginTop="16dp"
            android:background="#FFFFFF"
            app:layout_constraintTop_toBottomOf="@id/layoutPlanPrice"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Features ScrollView Content (Dynamically filled) -->
        <LinearLayout
            android:id="@+id/layoutPlanFeatures"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/planDivider"
            app:layout_constraintBottom_toTopOf="@id/btnChoosePlan"
            app:layout_constraintVertical_bias="0">
            <!-- Features added by Adapter -->
        </LinearLayout>

        <!-- Select Plan Button (Pinned to Bottom) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnChoosePlan"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Select Plan"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textStyle="bold|italic"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            app:cornerRadius="12dp"
            app:backgroundTint="#1AFFFFFF"
            app:strokeColor="#1AFFFFFF"
            app:strokeWidth="1dp"
            app:icon="@drawable/ic_payments"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
