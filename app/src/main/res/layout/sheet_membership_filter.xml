<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootFilterContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center"
        android:layout_marginBottom="24dp"
        android:background="#33FFFFFF" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Filtered by:"
        android:textAlignment="center"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:fontFamily="sans-serif-black"
        android:layout_marginBottom="24dp" />

    <!-- Section: Status -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Plan Status"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:fontFamily="sans-serif-black" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="12dp">

        <CheckBox
            android:id="@+id/cbStatusAll"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="All"
            android:textColor="@color/white"
            android:buttonTint="@color/white" />

        <CheckBox
            android:id="@+id/cbStatusPending"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Pending"
            android:textColor="@color/white"
            android:buttonTint="@color/white" />

        <CheckBox
            android:id="@+id/cbStatusApproved"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Approved"
            android:textColor="@color/white"
            android:buttonTint="@color/white" />
            
        <CheckBox
            android:id="@+id/cbStatusExpired"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Expired"
            android:textColor="@color/white"
            android:buttonTint="@color/white" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1AFFFFFF"
        android:layout_marginVertical="20dp" />

    <!-- Section: Date Range -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Date Range"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:fontFamily="sans-serif-black" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_search_modern"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_calendar"
                app:tint="@color/white"
                android:alpha="0.5" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="From"
                android:textColor="#4DFFFFFF"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:paddingStart="10dp" />

            <TextView
                android:id="@+id/tvFromDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:fontFamily="sans-serif-black"
                android:alpha="0.5" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_search_modern"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_calendar"
                app:tint="@color/white"
                android:alpha="0.5" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="To"
                android:textColor="#4DFFFFFF"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:paddingStart="10dp" />

            <TextView
                android:id="@+id/tvToDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:fontFamily="sans-serif-black"
                android:alpha="0.5" />
        </LinearLayout>

    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnApplyFilters"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="24dp"
        android:text="Apply Filters"
        android:fontFamily="sans-serif-black"
        app:cornerRadius="16dp" />

    <TextView
        android:id="@+id/tvClearAll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Clear all"
        android:textAlignment="center"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:fontFamily="sans-serif-black"
        android:alpha="0.6" />

</LinearLayout>
