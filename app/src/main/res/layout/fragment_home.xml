<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="32dp"
        android:paddingHorizontal="24dp"
        android:paddingBottom="48dp">

        <!-- Minimalist Header Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="58dp"
                android:layout_height="58dp"
                app:cardCornerRadius="29dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#1AFFFFFF"
                app:strokeColor="#33FFFFFF"
                app:strokeWidth="1dp">
                
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    
                    <ImageView
                        android:id="@+id/memberProfilePic"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/memberInitials"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="JD"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:fontFamily="sans-serif-black" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <TextView
                    android:id="@+id/dashGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hello,"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:alpha="0.6"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/dashUserName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="User"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="-0.02" />
            </LinearLayout>
        </LinearLayout>

        <!-- Dynamic Status Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="32dp">

            <!-- Booking Highlights (Sleek Glass Card) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/todayStatusCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#0DFFFFFF"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:strokeColor="#1AFFFFFF"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        app:cardBackgroundColor="#1A00C853"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp">
                        
                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_booking"
                            app:tint="@color/emerald_400" />
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="UPCOMING SESSION"
                            android:textColor="@color/white"
                            android:alpha="0.5"
                            android:textSize="10sp"
                            android:letterSpacing="0.1"
                            android:fontFamily="sans-serif-black" />

                        <TextView
                            android:id="@+id/sessionStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="No Active Bookings"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginTop="1dp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/btnBookNow"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BOOK"
                        android:textColor="@color/emerald_400"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-black"
                        android:padding="8dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Membership Info (Sleek Glass Card) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardMembership"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#0DFFFFFF"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:strokeColor="#1AFFFFFF"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        app:cardBackgroundColor="#1A7F13EC"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp">
                        
                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_membership"
                            app:tint="@color/landing_primary" />
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="MEMBERSHIP"
                            android:textColor="@color/white"
                            android:alpha="0.5"
                            android:textSize="10sp"
                            android:letterSpacing="0.1"
                            android:fontFamily="sans-serif-black" />

                        <TextView
                            android:id="@+id/membershipStatusText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="No Active Membership"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginTop="1dp" />
                        
                        <TextView
                            android:id="@+id/membershipPlan"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Plan: N/A"
                            android:textColor="@color/white"
                            android:textSize="12sp"
                            android:alpha="0.4"
                            android:visibility="gone"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:text="Services"
            android:textColor="@color/white"
            android:alpha="0.4"
            android:textSize="11sp"
            android:fontFamily="sans-serif-black"
            android:textAllCaps="true"
            android:letterSpacing="0.2" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:layout_marginTop="16dp"
            android:alignmentMode="alignMargins"
            android:useDefaultMargins="true">

            <!-- Grid Items with consistent Glass UI -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnNavBookSession"
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_columnWeight="1"
                app:cardBackgroundColor="#0DFFFFFF"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="#1AFFFFFF"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_booking" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Booking"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnNavPayment"
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_columnWeight="1"
                app:cardBackgroundColor="#0DFFFFFF"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="#1AFFFFFF"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_payment" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Payment"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnNavMembership"
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_columnWeight="1"
                app:cardBackgroundColor="#0DFFFFFF"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="#1AFFFFFF"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_membership" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Program"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnNavProfile"
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_columnWeight="1"
                app:cardBackgroundColor="#0DFFFFFF"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="#1AFFFFFF"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_profile" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Account"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </GridLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
