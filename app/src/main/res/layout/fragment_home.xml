<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="64dp"
        android:paddingHorizontal="24dp"
        android:paddingBottom="24dp">

        <!-- Welcome Header -->
        <TextView
            android:id="@+id/welcomeHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome Back,"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold|italic"
            android:fontFamily="sans-serif-black"
            android:textAllCaps="true"
            android:letterSpacing="-0.02" />

        <TextView
            android:id="@+id/dashUserName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ravee"
            android:textColor="@color/nav_active_color"
            android:textSize="28sp"
            android:textStyle="bold|italic"
            android:fontFamily="sans-serif-black"
            android:textAllCaps="true"
            android:letterSpacing="-0.02"
            android:layout_marginTop="-4dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/roleBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/badge_pill_border"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="MEMBER"
                android:textColor="@color/nav_active_color"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <TextView
                android:id="@+id/gymNameText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="GYM: LOADING..."
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.05" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Let's crush your goals today."
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:letterSpacing="0.1" />

        <!-- Status Cards -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="32dp">

            <!-- Today's Status Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/todayStatusCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/surface_dark"
                app:cardCornerRadius="32dp"
                app:cardElevation="0dp"
                app:strokeColor="#40FFFFFF"
                app:strokeWidth="1.5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TODAY'S STATUS"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/sessionStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="No Booking Today"
                        android:textColor="@color/white"
                        android:textSize="22sp"
                        android:textStyle="bold|italic"
                        android:textAllCaps="true" />

                    <TextView
                        android:id="@+id/sessionDetail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Ready for your next workout?"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/btnBookNow"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="Book Now"
                        android:textColor="@color/nav_active_color"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground"
                        android:padding="8dp"
                        android:layout_marginStart="-8dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Membership Status Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface_dark"
                app:cardCornerRadius="32dp"
                app:cardElevation="0dp"
                app:strokeColor="#40FFFFFF"
                app:strokeWidth="1.5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MEMBERSHIP STATUS"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/membershipStatusText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Active Member"
                        android:textColor="@color/emerald_400"
                        android:textSize="22sp"
                        android:textStyle="bold|italic"
                        android:textAllCaps="true" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="20dp"
                        android:background="#20FFFFFF" />

                    <TextView
                        android:id="@+id/membershipPlan"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Current Plan: Standard Access"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="56dp"
            android:text="QUICK ACTIONS"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:textStyle="bold|italic"
            android:textAllCaps="true"
            android:letterSpacing="0.15" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:layout_marginTop="16dp"
            android:alignmentMode="alignMargins"
            android:columnOrderPreserved="false"
            android:useDefaultMargins="true">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnNavBookSession"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_columnWeight="1"
                app:cardBackgroundColor="@color/surface_dark"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="#40FFFFFF"
                app:strokeWidth="1.5dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_booking"
                        app:tint="@color/nav_active_color" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="BOOKING SESSION"
                        android:gravity="center"
                        android:textColor="@color/white"
                        android:textSize="8sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnNavPayment"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_columnWeight="1"
                app:cardBackgroundColor="@color/surface_dark"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="#40FFFFFF"
                app:strokeWidth="1.5dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_payment"
                        app:tint="@color/amber_500" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="PAYMENT HISTORY"
                        android:gravity="center"
                        android:textColor="@color/white"
                        android:textSize="8sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnNavMembership"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_columnWeight="1"
                app:cardBackgroundColor="@color/surface_dark"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="#40FFFFFF"
                app:strokeWidth="1.5dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_membership"
                        app:tint="#A855F7" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="MEMBERSHIP"
                        android:gravity="center"
                        android:textColor="@color/white"
                        android:textSize="8sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </GridLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="60dp"
            android:layout_marginBottom="100dp"
            android:gravity="center"
            android:text="Horizon System v1.0.0"
            android:textColor="#33FFFFFF"
            android:textSize="12sp"
            android:textAllCaps="true"
            android:letterSpacing="0.1" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
