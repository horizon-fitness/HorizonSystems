<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/homeRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="32dp"
        android:paddingHorizontal="24dp"
        android:paddingBottom="48dp">

        <!-- Minimalist Header Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cvProfileImage"
                android:layout_width="60dp"
                android:layout_height="60dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#0DFFFFFF"
                app:strokeColor="#1AFFFFFF"
                app:strokeWidth="1dp">
                
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    
                    <ImageView
                        android:id="@+id/memberProfilePic"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/memberInitials"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="JD"
                        android:textColor="@color/white"
                        android:textSize="24sp"
                        android:fontFamily="sans-serif-black" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="20dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="bottom">

                    <TextView
                        android:id="@+id/dashGreeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="WELCOME "
                        android:textColor="@color/white"
                        android:textSize="30sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="-0.02" />

                    <TextView
                        android:id="@+id/dashUserName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="User"
                        android:textColor="#FFFFFF"
                        android:textSize="30sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="-0.02" />
                </LinearLayout>

                <TextView
                    android:id="@+id/dashSubGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="ARE YOU READY TO BE PRODUCTIVE?"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:alpha="0.4"
                    android:fontFamily="sans-serif-medium"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />
            </LinearLayout>
        </LinearLayout>

        <!-- Dynamic Status Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="32dp">

            <!-- Booking Highlights (Sleek Modern Card) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/todayStatusCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/surface_dark"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="#1AFFFFFF"
                app:strokeWidth="1dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="24dp">

                    <TextView
                        android:id="@+id/tvUpcomingLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="UPCOMING SESSION"
                        android:textColor="@color/landing_primary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent" />

                    <!-- Dumbbell Icon removed per user request -->


                    <TextView
                        android:id="@+id/sessionStatus"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="No Active Bookings"
                        android:textColor="@color/white"
                        android:textSize="24sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="-0.02"
                        app:layout_constraintTop_toBottomOf="@id/tvUpcomingLabel"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <LinearLayout
                        android:id="@+id/layoutSessionInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        app:layout_constraintTop_toBottomOf="@id/sessionStatus"
                        app:layout_constraintStart_toStartOf="parent">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_clock"
                            app:tint="@color/text_secondary"
                            android:alpha="0.6" />

                        <TextView
                            android:id="@+id/tvSessionTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:text="Stay productive!"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:alpha="0.8" />

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_marginStart="16dp"
                            android:src="@drawable/ic_location"
                            app:tint="@color/text_secondary"
                            android:alpha="0.6" />

                        <TextView
                            android:id="@+id/tvSessionLocation"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:text="---"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:alpha="0.8" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnBookNow"
                        android:layout_width="match_parent"
                        android:layout_height="62dp"
                        android:layout_marginTop="32dp"
                        android:text="View Details  →"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-black"
                        app:backgroundTint="@color/landing_primary"
                        app:cornerRadius="31dp"
                        app:layout_constraintTop_toBottomOf="@id/layoutSessionInfo"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Membership Info (Modern List Item Style) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardMembership"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface_dark"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="#1AFFFFFF"
                app:strokeWidth="1dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvMembershipLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MEMBERSHIP"
                        android:textColor="@color/text_secondary"
                        android:alpha="0.6"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintBottom_toTopOf="@id/membershipStatusText"
                        app:layout_constraintVertical_chainStyle="packed"/>

                    <TextView
                        android:id="@+id/membershipStatusText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="No Active Plan"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="-0.01"
                        app:layout_constraintTop_toBottomOf="@id/tvMembershipLabel"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/btnManageMembership"/>

                    <TextView
                        android:id="@+id/btnManageMembership"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Manage"
                        android:textColor="@color/landing_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <!-- Hidden old plan text to keep bindings working if needed -->
                    <TextView
                        android:id="@+id/membershipPlan"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="parent"/>

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>        <LinearLayout
            android:id="@+id/tvPlansLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MEMBERSHIP "
                android:textColor="@color/white"
                android:textSize="22sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="-0.02" />

            <TextView
                android:id="@+id/tvPlansHeaderPart2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PLANS"
                android:textColor="#A855F7"
                android:textSize="22sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="-0.02" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvMembershipPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:nestedScrollingEnabled="false"
            android:clipToPadding="false" />

        <LinearLayout
            android:id="@+id/emptyStatePlansHome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <ImageView
                android:id="@+id/ivEmptyPlansHome"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_clock"
                android:alpha="0.2"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/tvNoPlansHome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="No membership plan available"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:alpha="0.4"
                android:gravity="center" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutServicesHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SERVICES "
                    android:textColor="@color/white"
                    android:textSize="22sp"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="-0.02" />

                <TextView
                    android:id="@+id/tvServicesHeaderPart2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OFFERED"
                    android:textColor="#A855F7"
                    android:textSize="22sp"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="-0.02" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvServicesSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="SPECIALIZED SESSIONS AND RATES"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:alpha="0.4"
                android:fontFamily="sans-serif-medium"
                android:textStyle="bold"
                android:letterSpacing="0.1" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvServicesPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:nestedScrollingEnabled="false"
            android:clipToPadding="false" />

        <LinearLayout
            android:id="@+id/emptyStateServicesHome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <ImageView
                android:id="@+id/ivEmptyServicesHome"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_clock"
                android:alpha="0.2"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/tvNoServicesHome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="No service offered"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:alpha="0.4"
                android:gravity="center" />
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
