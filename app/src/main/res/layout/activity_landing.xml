<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayout"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/landing_background"
    android:fitsSystemWindows="true">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/innerLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#16131C"
            android:paddingBottom="48dp">

            <!-- Background Ambient Glows (Subtle but visible) -->
            <View
                android:id="@+id/ambientGlowTop"
                android:layout_width="450dp"
                android:layout_height="450dp"
                android:alpha="0.2"
                android:background="@drawable/ambient_glow"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_marginTop="-150dp"
                android:layout_marginEnd="-150dp" />

            <!-- Integrated Content Container -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="28dp"
                android:paddingTop="54dp"
                app:layout_constraintTop_toTopOf="parent">

                <!-- Logo Header -->
                <ImageView
                    android:id="@+id/imgLogo"
                    android:layout_width="140dp"
                    android:layout_height="42dp"
                    android:scaleType="fitStart"
                    android:src="@android:drawable/ic_menu_send" />

                <!-- Welcome Content -->
                <TextView
                    android:id="@+id/heroTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="56dp"
                    android:text="WELCOME BACK"
                    android:textColor="@color/white"
                    android:textSize="34sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.02" />

                <TextView
                    android:id="@+id/heroDescription"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="AUTHORIZED PERSONNEL ONLY"
                    android:textColor="#595466"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12" />

                <!-- Form Section (Integrated, not in a floating card) -->
                <LinearLayout
                    android:id="@+id/loginForm"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="64dp"
                    android:orientation="vertical">

                    <!-- Secure Access Badge -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/badge_pill_border"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="5dp"
                        android:text="SECURE ACCESS"
                        android:textColor="#99FFFFFF"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.18"
                        android:layout_marginBottom="32dp" />

                    <!-- Identity -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="IDENTITY"
                        android:textColor="#B0A6C7"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.2" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="62dp"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/input_dark_rounded"
                        android:backgroundTint="#221E2B"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="18dp">
                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@android:drawable/ic_menu_myplaces"
                            android:alpha="0.6"
                            app:tint="@color/white" />
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/usernameEdit"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginStart="14dp"
                            android:background="@null"
                            android:hint="Username"
                            android:textColor="@color/white"
                            android:textColorHint="#33FFFFFF"
                            android:textSize="15sp" />
                    </LinearLayout>

                    <!-- Security Key -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="32dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SECURITY KEY"
                            android:textColor="#B0A6C7"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.2" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="FORGOT?"
                            android:textColor="@color/landing_primary"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.08" />
                    </RelativeLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="62dp"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/input_dark_rounded"
                        android:backgroundTint="#221E2B"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="18dp">
                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@android:drawable/ic_lock_idle_lock"
                            android:alpha="0.6"
                            app:tint="@color/white" />
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/passwordEdit"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginStart="14dp"
                            android:background="@null"
                            android:hint="••••••••"
                            android:inputType="textPassword"
                            android:textColor="@color/white"
                            android:textColorHint="#33FFFFFF"
                            android:textSize="15sp" />
                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@android:drawable/ic_menu_view"
                            android:alpha="0.6"
                            app:tint="@color/white" />
                    </LinearLayout>

                    <!-- Authorize Button (Full Width Native) -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSignIn"
                        android:layout_width="match_parent"
                        android:layout_height="76dp"
                        android:layout_marginTop="42dp"
                        android:text="AUTHORIZE ENTRY    →"
                        android:textAllCaps="true"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        app:backgroundTint="@color/landing_primary"
                        app:cornerRadius="18dp"
                        app:elevation="4dp" />

                    <!-- Footer -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="48dp"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="NEW TO THE FAMILY? "
                            android:textColor="#4DFFFFFF"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CREATE ACCOUNT"
                            android:textColor="@color/landing_primary"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/contactTextFooter"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="72dp"
                    android:gravity="center"
                    android:text="© 2024 HORIZON SYSTEM. SECURE ENVIRONMENT."
                    android:textColor="#1AFFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.2" />

            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Loading Overlay -->
    <FrameLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E60A0A0A"
        android:elevation="100dp"
        android:visibility="visible"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical">

            <ProgressBar
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:indeterminateTint="@color/landing_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Securing Connection..."
                android:textColor="@color/white"
                android:textSize="14sp"
                android:alpha="0.7"
                android:letterSpacing="0.05" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnManualBypass"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Continue anyway »"
                android:textAllCaps="false"
                android:textColor="@color/landing_primary"
                android:visibility="gone" />
        </LinearLayout>
    </FrameLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>