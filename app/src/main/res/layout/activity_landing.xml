<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayout"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/landing_background"
    android:fitsSystemWindows="true">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Dash Container (Hidden by default, used for dashboard after login) -->
            <LinearLayout
                android:id="@+id/dashContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <FrameLayout
                    android:id="@+id/fragment_container"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <com.google.android.material.bottomnavigation.BottomNavigationView
                    android:id="@+id/bottomNavigationView"
                    style="@style/Widget.App.BottomNavigationView"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:background="@color/landing_background"
                    app:elevation="8dp"
                    app:itemIconSize="26dp"
                    app:itemIconTint="@color/nav_item_selector"
                    app:labelVisibilityMode="unlabeled" />
            </LinearLayout>

            <!-- Premium Ambient Background Glow (Moved out of inner layout to avoid height issues) -->
            <View
                android:layout_width="600dp"
                android:layout_height="600dp"
                android:alpha="0.2"
                android:background="@drawable/ambient_glow"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_marginEnd="-300dp"
                android:layout_marginTop="-200dp" />

            <!-- Login Container (shifted up slightly and vertical padding removed for tighter fit) -->
            <LinearLayout
                android:id="@+id/loginContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="32dp"
                android:orientation="vertical"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="40dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="32dp">

                    <LinearLayout
                        android:id="@+id/innerLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent">

                        <TextView
                            android:id="@+id/tenantTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            android:text="HORIZON SYSTEMS"
                            android:textColor="@color/white"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-black"
                            android:letterSpacing="0.05" />

                        <!-- Logo Section -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="120dp"
                            android:layout_height="120dp"
                            android:layout_marginBottom="16dp"
                            app:cardBackgroundColor="#1AFFFFFF"
                            app:cardCornerRadius="64dp"
                            app:cardElevation="0dp">
                            <ImageView
                                android:id="@+id/gymLogo"
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_dumbbell"
                                app:tint="@color/nav_active_color" />
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Header Section -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:layout_marginBottom="4dp">

                            <TextView
                                android:id="@+id/heroTitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="WELCOME BACK"
                                android:textColor="@color/white"
                                android:textSize="32sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-black"
                                android:letterSpacing="-0.02"
                                android:gravity="center" />

                            <TextView
                                android:id="@+id/heroDescription"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="Enter your credentials to access your account."
                                android:textColor="@color/text_secondary"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-medium"
                                android:paddingHorizontal="16dp"
                                android:alpha="0.8"
                                android:gravity="center" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Input Fields -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Username:"
                    android:textColor="#CCFFFFFF"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp"
                    android:layout_gravity="start"
                    android:fontFamily="sans-serif-medium" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:background="@drawable/input_field_bg"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="20dp"
                    android:layout_marginBottom="24dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_profile"
                        app:tint="#80FFFFFF" />
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/usernameEdit"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginStart="16dp"
                        android:background="@null"
                        android:hint="Enter username"
                        android:textColor="@color/white"
                        android:textColorHint="#40FFFFFF"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Password:"
                    android:textColor="#CCFFFFFF"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp"
                    android:layout_gravity="start"
                    android:fontFamily="sans-serif-medium" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:background="@drawable/input_field_bg"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="20dp"
                    android:layout_marginBottom="16dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_lock_idle_lock"
                        app:tint="#80FFFFFF" />
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/passwordEdit"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:background="@null"
                        android:hint="Enter password"
                        android:inputType="textPassword"
                        android:textColor="@color/white"
                        android:textColorHint="#40FFFFFF"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium" />
                    <ImageView
                        android:id="@+id/btnTogglePassword"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_view"
                        android:alpha="0.5"
                        app:tint="#80FFFFFF"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>

                <!-- Options Row -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="40dp">
                    <CheckBox
                        android:id="@+id/rememberMe"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Remember Me"
                        android:textColor="#80FFFFFF"
                        android:textSize="13sp"
                        android:buttonTint="@color/nav_active_color"
                        android:fontFamily="sans-serif-medium" />
                    <TextView
                        android:id="@+id/btnForgotPassword"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="Forgot Password?"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:clickable="true"
                        android:focusable="true" />
                </RelativeLayout>

                <!-- Login Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSignIn"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:text="Login"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    app:backgroundTint="@null"
                    android:background="@drawable/button_premium"
                    app:elevation="4dp"
                    android:fontFamily="sans-serif-black" />

                <!-- Divider -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:layout_marginBottom="24dp"
                    android:gravity="center"
                    android:orientation="horizontal">
                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#20FFFFFF" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="16dp"
                        android:text="OR"
                        android:textColor="#40FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#20FFFFFF" />
                </LinearLayout>

                <!-- Switch Gym Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSwitchGym"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:text="Switch Gym"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    app:strokeColor="#20FFFFFF"
                    app:strokeWidth="1dp"
                    app:cornerRadius="12dp"
                    app:icon="@drawable/ic_qr_code"
                    app:iconTint="@color/nav_active_color"
                    app:iconGravity="textStart"
                    app:iconPadding="12dp"
                    android:fontFamily="sans-serif-medium" />

                <!-- Footer -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="48dp"
                    android:layout_gravity="center"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Don't have an account yet?"
                        android:textColor="#80FFFFFF"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginEnd="4dp" />
                    <TextView
                        android:id="@+id/btnCreateAccount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sign Up"
                        android:textColor="@color/nav_active_color"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-black"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>

                <TextView
                    android:id="@+id/contactTextFooter"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="40dp"
                    android:gravity="center"
                    android:text="© 2026 HORIZON SYSTEM"
                    android:textColor="#66FFFFFF"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.1" />

            </LinearLayout> <!-- End Login Container -->
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Loading Overlay -->
    <FrameLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E6050505"
        android:elevation="100dp"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical">

            <ProgressBar
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:indeterminateTint="@color/nav_active_color" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Horizon Secure Link..."
                android:textColor="@color/white"
                android:textSize="15sp"
                android:alpha="0.8"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.05" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnManualBypass"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Manual Entry »"
                android:textAllCaps="false"
                android:textColor="@color/landing_primary"
                android:textSize="13sp"
                android:fontFamily="sans-serif-black"
                android:visibility="gone" />
        </LinearLayout>
    </FrameLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>