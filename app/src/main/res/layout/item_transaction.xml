<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingHorizontal="24dp"
    android:paddingVertical="16dp"
    android:gravity="center_vertical">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingVertical="18dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:orientation="vertical"
            android:layout_toStartOf="@+id/rightGroup">

            <TextView
                android:id="@+id/txnService"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Unlimited Gym Use"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:ellipsize="end"
                android:maxLines="1" />

            <TextView
                android:id="@+id/txnRef"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Ref: GCASH-12345"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:fontFamily="sans-serif"
                android:alpha="0.7" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rightGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:gravity="end"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txnAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₱500.00"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black" />

            <TextView
                android:id="@+id/txnDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Mar 21, 2024"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.02" />

            <TextView
                android:id="@+id/txnTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:text="10:00 AM" />
        </LinearLayout>

    </RelativeLayout>

</LinearLayout>
