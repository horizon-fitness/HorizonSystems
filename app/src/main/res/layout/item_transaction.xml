<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardBackgroundColor="#141216"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="#1AFFFFFF">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <!-- Date Block (Left) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardDateBlock"
            android:layout_width="72dp"
            android:layout_height="72dp"
            app:cardBackgroundColor="#0D0B0E"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvTxnMonth"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OCT"
                    android:textColor="#94A3B8"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-black"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tvTxnDay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="16"
                    android:textColor="#BC8CF2"
                    android:textSize="22sp"
                    android:fontFamily="sans-serif-black" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Service & Details -->
        <TextView
            android:id="@+id/txnService"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:text="Strength &amp; Conditioning"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:fontFamily="sans-serif-black"
            android:ellipsize="end"
            android:maxLines="2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/cardDateBlock"
            app:layout_constraintTop_toTopOf="@id/cardDateBlock" />

        <LinearLayout
            android:id="@+id/layoutTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintTop_toBottomOf="@id/txnService"
            app:layout_constraintStart_toStartOf="@id/txnService"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_clock"
                app:tint="#4DFFFFFF" />

            <TextView
                android:id="@+id/txnDateTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="08:00 AM - 09:30 AM"
                android:textColor="#80FFFFFF"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <!-- Subtitle/Reference (Secondary Info) -->
        <TextView
            android:id="@+id/txnReference"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Ref: TRANS-123456"
            android:textColor="#4DFFFFFF"
            android:textSize="10sp"
            android:fontFamily="sans-serif-medium"
            android:textAllCaps="true"
            android:letterSpacing="0.05"
            app:layout_constraintTop_toBottomOf="@id/layoutTime"
            app:layout_constraintStart_toStartOf="@id/txnService" />

        <!-- Status Badge -->
        <TextView
            android:id="@+id/txnStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/badge_status_bg"
            android:paddingHorizontal="14dp"
            android:paddingVertical="6dp"
            android:text="Approved"
            android:textColor="#34D399"
            android:textSize="11sp"
            android:fontFamily="sans-serif-black"
            app:layout_constraintTop_toBottomOf="@id/cardDateBlock"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- More Options -->
        <ImageView
            android:id="@+id/btnTxnMore"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_more_vert"
            app:tint="#4DFFFFFF"
            app:layout_constraintBottom_toBottomOf="@id/txnStatus"
            app:layout_constraintTop_toTopOf="@id/txnStatus"
            app:layout_constraintStart_toEndOf="@id/txnStatus"
            android:layout_marginStart="20dp" />

        <!-- Price (Optional align right) -->
        <TextView
            android:id="@+id/txnAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="₱1,500"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:fontFamily="sans-serif-black"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
