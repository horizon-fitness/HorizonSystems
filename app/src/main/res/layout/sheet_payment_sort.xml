<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootSortContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center"
        android:layout_marginBottom="24dp"
        android:background="#33FFFFFF" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sort by"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:fontFamily="sans-serif-black" />

    <RadioGroup
        android:id="@+id/rgSortOptions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp">

        <com.google.android.material.radiobutton.MaterialRadioButton
            android:id="@+id/rbNewest"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Newest First"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium"
            app:buttonTint="@color/white" />

        <com.google.android.material.radiobutton.MaterialRadioButton
            android:id="@+id/rbOldest"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Oldest First"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium"
            app:buttonTint="@color/white" />

        <com.google.android.material.radiobutton.MaterialRadioButton
            android:id="@+id/rbHighPrice"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Price: High to Low"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium"
            app:buttonTint="@color/white" />

        <com.google.android.material.radiobutton.MaterialRadioButton
            android:id="@+id/rbLowPrice"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Price: Low to High"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium"
            app:buttonTint="@color/white" />
    </RadioGroup>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnApplySort"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="24dp"
        android:text="Apply"
        android:fontFamily="sans-serif-black"
        app:cornerRadius="16dp" />

</LinearLayout>
