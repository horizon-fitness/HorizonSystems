<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootFilterContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center"
        android:layout_marginBottom="24dp"
        android:background="#33FFFFFF" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Filtered by:"
        android:textAlignment="center"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:fontFamily="sans-serif-black"
        android:layout_marginBottom="24dp" />

    <!-- Section: Category -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Category"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:fontFamily="sans-serif-black" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/cgType"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:singleSelection="true">

        <com.google.android.material.chip.Chip
            android:id="@+id/chipTypeAll"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="All"
            app:chipBackgroundColor="#0DFFFFFF"
            android:textColor="@color/white" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipTypeMembership"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Membership"
            app:chipBackgroundColor="#0DFFFFFF"
            android:textColor="@color/white" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipTypeBooking"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Booking"
            app:chipBackgroundColor="#0DFFFFFF"
            android:textColor="@color/white" />
    </com.google.android.material.chip.ChipGroup>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1AFFFFFF"
        android:layout_marginVertical="20dp" />

    <!-- Section: Result (Status) -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Status"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:fontFamily="sans-serif-black" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="12dp">

        <CheckBox
            android:id="@+id/cbStatusAll"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="All"
            android:textColor="@color/white"
            android:buttonTint="@color/white" />

        <CheckBox
            android:id="@+id/cbStatusPending"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Pending"
            android:textColor="@color/white"
            android:buttonTint="@color/white" />

        <CheckBox
            android:id="@+id/cbStatusCompleted"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Completed"
            android:textColor="@color/white"
            android:buttonTint="@color/white" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1AFFFFFF"
        android:layout_marginVertical="20dp" />

    <!-- Section: Date -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Date"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:fontFamily="sans-serif-black" />

    <CalendarView
        android:id="@+id/calendarFilter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:theme="@style/CustomCalendarViewTheme" />

    <!-- Combined Footer Actions -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnApplyFilters"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="24dp"
        android:text="Apply"
        android:fontFamily="sans-serif-black"
        app:cornerRadius="16dp" />

    <TextView
        android:id="@+id/tvClearAll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Clear all"
        android:textAlignment="center"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:fontFamily="sans-serif-black"
        android:alpha="0.6" />

</LinearLayout>
