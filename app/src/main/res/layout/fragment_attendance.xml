<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/attendanceRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0a090d">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">

            <!-- Header Section -->
            <TextView
                android:id="@+id/tvAttendanceTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="-0.02"
                android:text="ATTENDANCE"
                android:textColor="@color/white"
                android:textSize="28sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />


            <TextView
                android:id="@+id/tvAttendanceThemeSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:alpha="0.6"
                android:fontFamily="sans-serif-medium"
                android:text="Track your consistency"
                android:textColor="#A855F7"
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvAttendanceTitle" />

            <LinearLayout
                android:id="@+id/attendance_tabs_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="horizontal"
                android:weightSum="2"
                app:layout_constraintTop_toBottomOf="@id/tvAttendanceThemeSubtitle">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_tab_scan_web"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.05"
                    android:text="SCAN WEB"
                    android:textColor="#A855F7"
                    android:textSize="10sp"
                    android:backgroundTint="#1AA855F7"
                    app:cornerRadius="10dp"
                    app:rippleColor="#33FFFFFF" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_tab_my_qr"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.05"
                    android:text="MY QR CODE"
                    android:textColor="#94A3B8"
                    android:textSize="10sp"
                    android:backgroundTint="@android:color/transparent"
                    app:cornerRadius="10dp"
                    app:rippleColor="#33FFFFFF" />
            </LinearLayout>

            <!-- QR Scanner Card (Integrated Camera) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardScanner"
                android:layout_width="match_parent"
                android:layout_height="320dp"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="#0DFFFFFF"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="#1AFFFFFF"
                app:strokeWidth="1dp"
                app:layout_constraintTop_toBottomOf="@id/attendance_tabs_container">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <androidx.camera.view.PreviewView
                        android:id="@+id/attendancePreviewView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:visibility="invisible"
                        app:scaleType="fillCenter" />

                    <!-- Launch Trigger Overlay -->
                    <LinearLayout
                        android:id="@+id/layoutStartScanner"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:background="#1AFFFFFF"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/ivLaunchScannerIcon"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:src="@drawable/ic_qr_code"
                            app:tint="@color/white" />

                        <TextView
                            android:id="@+id/tvLaunchScannerLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:fontFamily="sans-serif-black"
                            android:letterSpacing="0.05"
                            android:text="TAP TO LAUNCH SCANNER"
                            android:textColor="@color/white"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Scanner Overlay (Stylized - Hidden initially) -->
                    <View
                        android:id="@+id/vScannerOverlay"
                        android:layout_width="200dp"
                        android:layout_height="200dp"
                        android:background="@drawable/badge_pill_border"
                        android:alpha="0.3"
                        android:visibility="gone"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <ImageView
                        android:id="@+id/ivScannerIcon"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_qr_code"
                        android:alpha="0.2"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- My QR Code Card (Hidden initially) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardMyQR"
                android:layout_width="match_parent"
                android:layout_height="320dp"
                android:layout_marginTop="24dp"
                android:visibility="gone"
                app:cardBackgroundColor="#0DFFFFFF"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="#1AFFFFFF"
                app:strokeWidth="1dp"
                app:layout_constraintTop_toBottomOf="@id/attendance_tabs_container">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="216dp"
                        android:layout_height="216dp"
                        app:cardCornerRadius="16dp"
                        app:cardBackgroundColor="@color/white"
                        app:cardElevation="0dp">
                        
                        <ImageView
                            android:id="@+id/ivMyQrCode"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="8dp"
                            android:scaleType="fitCenter" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Present this code to the admin"
                        android:textColor="@color/white"
                        android:alpha="0.4"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Dynamic Barrier so Logs always stay below whatever card is visible -->
            <androidx.constraintlayout.widget.Barrier
                android:id="@+id/cardBarrier"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:barrierDirection="bottom"
                app:constraint_referenced_ids="cardScanner,cardMyQR" />

            <!-- Logs Section -->
            <TextView
                android:id="@+id/tvLogsLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.05"
                android:text="ATTENDANCE LOGS"
                android:textColor="@color/white"
                android:textSize="12sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardBarrier" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvAttendanceLogs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/tvLogsLabel" />

            <!-- Empty State -->
            <LinearLayout
                android:id="@+id/emptyStateAttendance"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:gravity="center"
                android:orientation="vertical"
                app:layout_constraintTop_toBottomOf="@id/tvLogsLabel">

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:alpha="0.1"
                    android:src="@drawable/ic_calendar"
                    app:tint="@color/white" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:alpha="0.3"
                    android:fontFamily="sans-serif-medium"
                    android:text="No logs found for this period"
                    android:textColor="@color/white"
                    android:textSize="14sp" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
