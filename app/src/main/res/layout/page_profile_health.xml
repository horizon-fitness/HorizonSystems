<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="28dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/headerHealth"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="4. HEALTH &amp; DETAILS"
            android:textColor="#FFFFFF"
            android:textSize="9sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:letterSpacing="0.15"
            android:layout_marginBottom="16dp" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Occupation"
            android:layout_marginBottom="12dp"
            app:boxStrokeColor="#FFFFFF"
            app:hintTextColor="#FFFFFF">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editOccupation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Medical History / Allergies"
            android:layout_marginBottom="24dp"
            app:boxStrokeColor="#FFFFFF"
            app:hintTextColor="#FFFFFF">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editMedical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:inputType="textMultiLine"
                android:lines="2" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/headerMetrics"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PHYSICAL ASSESSMENT"
            android:textColor="#FFFFFF"
            android:textSize="9sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:letterSpacing="0.15"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Height (cm)"
                android:layout_marginEnd="6dp"
                app:boxStrokeColor="#FFFFFF"
                app:hintTextColor="#FFFFFF">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editHeightCm"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:inputType="numberDecimal" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Weight (kg)"
                android:layout_marginStart="6dp"
                app:boxStrokeColor="#FFFFFF"
                app:hintTextColor="#FFFFFF">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editWeightKg"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:inputType="numberDecimal" />
            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Calculated BMI"
            android:layout_marginBottom="24dp"
            app:boxStrokeColor="#FFFFFF"
            app:hintTextColor="#FFFFFF">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editBmiVal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:focusable="false"
                android:clickable="false"
                android:focusableInTouchMode="false"
                android:inputType="none" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/headerEmergency"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EMERGENCY CONTACT"
            android:textColor="#FFFFFF"
            android:textSize="9sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:letterSpacing="0.15"
            android:layout_marginBottom="16dp" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Contact Person"
            android:layout_marginBottom="12dp"
            app:boxStrokeColor="#FFFFFF"
            app:hintTextColor="#FFFFFF">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editEmergencyName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:inputType="textPersonName" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Emergency Number"
            android:layout_marginBottom="32dp"
            app:boxStrokeColor="#FFFFFF"
            app:hintTextColor="#FFFFFF">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editEmergencyPhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:inputType="phone" />
        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
